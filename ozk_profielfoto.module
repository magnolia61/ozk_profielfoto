<?php

/**
 * Implements hook_entity_insert().
 * Vervangt de Rule: "Entityform Profielfoto Upload"
 */
function ozk_profielfoto_entity_insert($entity, $type) {
	if ($type === 'entityform' && $entity->type === 'profielfoto') {
		_ozk_profielfoto_sync_profielfoto_naar_civicrm($entity);
	}
}

/**
 * Implements hook_entity_update().
 * Vervangt de Rule: "Entityform Profielfoto Update"
 */
function ozk_profielfoto_entity_update($entity, $type) {
	if ($type === 'entityform' && $entity->type === 'profielfoto') {
		_ozk_profielfoto_sync_profielfoto_naar_civicrm($entity);
	}
}

/**
 * Implements hook_form_alter().
 */
function ozk_profielfoto_form_alter(&$form, &$form_state, $form_id) {
    if ($form_id === 'profielfoto_entityform_edit_form' || $form_id === 'entityform_edit_form') {
        $bundle = isset($form['#bundle']) ? $form['#bundle'] : '';
        if ($bundle === 'profielfoto' || $form_id === 'profielfoto_entityform_edit_form') {
            
            // DEBUG: Bevestig dat de alter is geladen
            watchdog('ozk_profielfoto', "Form alter actief voor: @id", ['@id' => $form_id], WATCHDOG_DEBUG);
            
            $form['actions']['submit']['#submit'][] = '_ozk_profielfoto_profielfoto_redirect_force';
        }
    }
}

/**
 * Geforceerde redirect handler.
 */
function _ozk_profielfoto_profielfoto_redirect_force($form, &$form_state) {
    if (isset($_GET['destination'])) {
        // DEBUG: Log als er een destination wordt gedwarsboomd
        watchdog('ozk_profielfoto', "Destination '@dest' verwijderd voor redirect.", ['@dest' => $_GET['destination']], WATCHDOG_DEBUG);
        unset($_GET['destination']);
    }
    
    $form_state['redirect'] = 'account';
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_sync_profielfoto_naar_civicrm
 * =======================================================================================
 * Haalt de geüploade foto uit de Entityform en pusht ENKEL de absolute URL naar CiviCRM.
 * Dit triggert automatisch de intake_civicrm_pre hook in intake.php, die de 
 * datums (custom_2253 en custom_1798) perfect en zonder timing-conflicten beheert.
 */
function _ozk_profielfoto_sync_profielfoto_naar_civicrm($entity) {
	$extdebug				= 'intake.profielfoto'; 

	// 1. Controleer of er een bestand is geüpload
	$field_data				= field_get_items('entityform', $entity, 'field_profielfoto');
	
	if (!$field_data || empty($field_data[0]['uri'])) {
		return; 
	}

	// 2. Converteer de Drupal URI naar een absolute URL en delegeer de CiviCRM-sync.
	$image_url				= file_create_url($field_data[0]['uri']);
	_ozk_profielfoto_push_image_url_naar_civicrm($entity->uid, $image_url);
}

/**
 * =======================================================================================
 * HELPER (testbare seam): _ozk_profielfoto_push_image_url_naar_civicrm
 * =======================================================================================
 * Pusht een absolute image-URL naar CiviCRM voor een gegeven Drupal-UID en stuurt de
 * notificatiemail. Afgesplitst van _ozk_profielfoto_sync_profielfoto_naar_civicrm() zodat
 * e2e-tests de volledige sync -> intake-pre-hook -> DB-keten kunnen draaien zonder de
 * Drupal-only field_get_items()/file_create_url() te stubben (die in de e2e-boot niet te
 * overschrijven zijn omdat Drupal's eigen versie al geladen is).
 */
function _ozk_profielfoto_push_image_url_naar_civicrm($uid, $image_url) {
	$extdebug				= 'intake.profielfoto';

	if (!civicrm_initialize()) {
		return;
	}

	$contact_id				= CRM_Core_BAO_UFMatch::getContactId($uid);

	if ($contact_id) {
		
		wachthond($extdebug, 2, "########################################################################");
		wachthond($extdebug, 1, "### DRUPAL SYNC: PROFIELFOTO NAAR CIVICRM PUSHEN",		"[CID: $contact_id]");
		wachthond($extdebug, 2, "########################################################################");

		// 3. APIv4 Parameters opbouwen (Alleen URL, intake.php pre-hook doet de rest)
		$params_update_foto = [
			'checkPermissions'	=> FALSE,
			'where'				=> [['id', '=', $contact_id]],
			'values'			=> ['image_URL' => $image_url],
		];
		
		wachthond($extdebug, 7, 'params_update_foto',			$params_update_foto);

		try {
			// 4. Push Foto URL via APIv4
			$result_foto	= civicrm_api4('Contact', 'update', $params_update_foto);
			wachthond($extdebug, 9, 'result_foto',					$result_foto);
			
			watchdog('ozk_profielfoto', "Profielfoto URL succesvol gesynchroniseerd voor CID: $contact_id", NULL, WATCHDOG_INFO);

			// 5. E-mail notificatie versturen (met Ymd_His timestamp)
			// ... binnen de _ozk_profielfoto_sync_profielfoto_naar_civicrm functie ...

			// Displayname ophalen via APIv4
			$params_contact_naam = [
				'checkPermissions' => FALSE,
				'debug'            => FALSE,
				'select'           => ['display_name'],
				'where'            => [['id', '=', $contact_id]],
			];
			wachthond($extdebug, 7, 'params_contact_naam',  $params_contact_naam);
			$result_contact_naam = civicrm_api4('Contact', 'get', $params_contact_naam);
			wachthond($extdebug, 9, 'result_contact_naam',  $result_contact_naam);
			$display_name        = $result_contact_naam->first()['display_name'] ?? '(onbekend)';

			// Ditjaar kampkort en kampfunctie via base_find_allpart
			$allpart_array       = function_exists('base_find_allpart') ? base_find_allpart($contact_id) : FALSE;
			$ditjaar_kampkort    = $allpart_array ? ($allpart_array['result_allpart_one_kampkort']    ?? NULL) : NULL;
			$ditjaar_kampfunctie = $allpart_array ? ($allpart_array['result_allpart_one_kampfunctie'] ?? NULL) : NULL;
			wachthond($extdebug, 3, 'ditjaar_kampkort',     $ditjaar_kampkort);
			wachthond($extdebug, 3, 'ditjaar_kampfunctie',  $ditjaar_kampfunctie);

			$email_to       = 'richard.van.oosterhout@gmail.com';
			$email_subject  = '[CRM] Profielfoto update - ' . date('Ymd_His');

			// Link naar het CiviCRM-contactrecord (admin is ingelogd). Dient tevens als
			// betrouwbare fallback: mailclients blokkeren/proxyen vaak de inline-hotlink van
			// een externe afbeelding, dus via deze link is de foto altijd te bekijken.
			$contact_view_url = 'https://www.onvergetelijk.nl/civicrm/contact/view?reset=1&cid=' . $contact_id;

			// --- Kan de foto INLINE mee (cid) i.p.v. hotlinken? ---
			// Leid het lokale bestandspad af uit de absolute URL. Lukt dat en is het een
			// leesbaar plaatje, dan sturen we 'm inline mee (multipart/related + Content-ID):
			// de afbeelding zit dan ÍN de mail, dus de client hoeft niets extern op te halen
			// -> altijd zichtbaar, ongeacht image-proxy/blokkade/afzenderreputatie. Anders
			// vallen we terug op de hotlink-<img> (huidig gedrag).
			$webroot   = '/var/www/vhosts/ozkprod/web';
			$urlPath   = parse_url($image_url, PHP_URL_PATH);
			$urlPath   = preg_replace('#/styles/[^/]+/public#', '', (string) $urlPath);   // defensief: styled -> origineel
			$localPath = $webroot . urldecode((string) $urlPath);
			$ext       = strtolower(pathinfo($localPath, PATHINFO_EXTENSION));
			$mimeMap   = ['jpg' => 'image/jpeg', 'jpeg' => 'image/jpeg', 'png' => 'image/png', 'gif' => 'image/gif'];
			$canEmbed  = isset($mimeMap[$ext]) && is_file($localPath) && is_readable($localPath);

			// HTML-body (de <img>-bron verschilt: cid bij inline, anders de hotlink-URL).
			$imgSrc = $canEmbed ? 'cid:profielfoto' : $image_url;
			$email_bericht  = '<html><body>';
			$email_bericht .= 'Profielfoto aangepast voor Contact ID: ' . $contact_id . '<br>';
			$email_bericht .= '<b>' . htmlspecialchars($display_name) . '</b><br>';   // naam op eigen regel
			if ($ditjaar_kampkort || $ditjaar_kampfunctie) {
				$email_bericht .= 'Kamp: ' . htmlspecialchars($ditjaar_kampkort ?? '?');
				$email_bericht .= ' &mdash; Functie: ' . htmlspecialchars($ditjaar_kampfunctie ?? '?');
				$email_bericht .= '<br>';
			}
			$email_bericht .= '<br><i>Deze foto is geüpload via het entityform (zelf-upload door de gebruiker).</i><br>';
			$email_bericht .= '<br><hr>';
			$email_bericht .= '<h3><b>Profielfoto</b></h3>';
			$email_bericht .= '<a href="' . $contact_view_url . '">';
			$email_bericht .= '<img src="' . $imgSrc . '" width="256px" style="border: 3px solid #A7A7A7; padding: 3px; margin: 3px;">';
			$email_bericht .= '</a><br><hr>';
			$email_bericht .= '<a href="' . $contact_view_url . '">&raquo; Open contactrecord in CiviCRM</a><br>';
			$email_bericht .= '</body></html>';

			if ($canEmbed) {
				// multipart/related: HTML-deel + inline-afbeelding gekoppeld via Content-ID.
				$boundary       = 'ozkfoto_' . md5(uniqid('', TRUE));
				$imgFilename    = basename($localPath);
				$imgData        = chunk_split(base64_encode(file_get_contents($localPath)));

				$email_headers  = "MIME-Version: 1.0" . "\r\n";
				$email_headers .= "From: noreply@onvergetelijk.nl" . "\r\n";
				$email_headers .= "Content-Type: multipart/related; boundary=\"$boundary\"" . "\r\n";

				$body  = "--$boundary\r\n";
				$body .= "Content-Type: text/html; charset=UTF-8\r\n";
				$body .= "Content-Transfer-Encoding: 8bit\r\n\r\n";
				$body .= $email_bericht . "\r\n\r\n";
				$body .= "--$boundary\r\n";
				$body .= "Content-Type: {$mimeMap[$ext]}; name=\"$imgFilename\"\r\n";
				$body .= "Content-Transfer-Encoding: base64\r\n";
				$body .= "Content-ID: <profielfoto>\r\n";
				$body .= "Content-Disposition: inline; filename=\"$imgFilename\"\r\n\r\n";
				$body .= $imgData . "\r\n";
				$body .= "--$boundary--";

				_ozk_profielfoto_mail($email_to, $email_subject, $body, $email_headers);
			}
			else {
				// Fallback: enkelvoudige HTML-mail met hotlink-afbeelding.
				$email_headers  = "MIME-Version: 1.0" . "\r\n";
				$email_headers .= "Content-Type: text/html; charset=UTF-8" . "\r\n";
				$email_headers .= "From: noreply@onvergetelijk.nl" . "\r\n";

				_ozk_profielfoto_mail($email_to, $email_subject, $email_bericht, $email_headers);
			}

			wachthond($extdebug, 3, "E-mail notificatie verzonden naar",	$email_to);

		} catch (\Exception $e) {
			$error_msg			= $e->getMessage();
			wachthond($extdebug, 1, "FATAAL: Fout bij pushen profielfoto naar CiviCRM",	$error_msg);
			watchdog('ozk_profielfoto', "Fout bij pushen profielfoto: $error_msg", NULL, WATCHDOG_ERROR);
		}
	} else {
		watchdog('ozk_profielfoto', "Geen CiviCRM contact gevonden voor Drupal UID: $uid", NULL, WATCHDOG_WARNING);
	}
}

/**
 * Wrapper rond mail() zodat de aanroep unit-testbaar is.
 * In productie roept dit gewoon de PHP mail()-functie aan.
 * In tests wordt deze functie eerder gedefinieerd door de bootstrap-stub.
 */
if (!function_exists('_ozk_profielfoto_mail')) {
    function _ozk_profielfoto_mail(string $to, string $subject, string $message, string $headers = ''): bool {
        return mail($to, $subject, $message, $headers);
    }
}
