<?php

/**
 * Implements hook_entity_insert().
 * Vervangt de Rule: "Entityform Profielfoto Upload"
 */
function ozk_profielfoto_entity_insert($entity, $type) {
    if ($type === 'entityform' && $entity->type === 'profielfoto') {
        if (!defined('OZK_PROFIELFOTO_AUTOCROP_ALTIJD')) {
            define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', TRUE);
        }
        if (OZK_PROFIELFOTO_AUTOCROP_ALTIJD || _ozk_profielfoto_is_mobiel()) {
            _ozk_profielfoto_autocrop_op_gezicht($entity);
        }
        _ozk_profielfoto_sync_profielfoto_naar_civicrm($entity);
    }
}

/**
 * Implements hook_entity_update().
 * Vervangt de Rule: "Entityform Profielfoto Update"
 */
function ozk_profielfoto_entity_update($entity, $type) {
    if ($type === 'entityform' && $entity->type === 'profielfoto') {
        if (!defined('OZK_PROFIELFOTO_AUTOCROP_ALTIJD')) {
            define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', TRUE);
        }
        if (OZK_PROFIELFOTO_AUTOCROP_ALTIJD || _ozk_profielfoto_is_mobiel()) {
            _ozk_profielfoto_autocrop_op_gezicht($entity);
        }
        _ozk_profielfoto_sync_profielfoto_naar_civicrm($entity);
    }
}

/**
 * Implements hook_form_alter().
 */
function ozk_profielfoto_form_alter(&$form, &$form_state, $form_id) {
    if ($form_id === 'profielfoto_entityform_edit_form' || $form_id === 'entityform_edit_form') {
        $bundle = isset($form['#bundle']) ? $form['#bundle'] : '';
        if ($bundle === 'profielfoto' || $form_id === 'profielfoto_entityform_edit_form') {
            
            // DEBUG: Bevestig dat de alter is geladen
            watchdog('ozk_profielfoto', "Form alter actief voor: @id", ['@id' => $form_id], WATCHDOG_DEBUG);

            $form['actions']['submit']['#submit'][] = '_ozk_profielfoto_profielfoto_redirect_force';

            // Schakelaar: TRUE = autocrop altijd server-side (manualcrop verborgen).
            //             FALSE = manualcrop zichtbaar voor desktop, autocrop alleen op mobiel.
            define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', TRUE);

            if (OZK_PROFIELFOTO_AUTOCROP_ALTIJD) {
                // Verberg de manualcrop-thumblist volledig via CSS en onderdruk de validatie.
                $form['#validate'][]    = '_ozk_profielfoto_crop_fout_vertalen';
                drupal_add_css(
                    '.manualcrop-thumblist, .ozk-crop-hint { display:none !important; }',
                    ['type' => 'inline', 'group' => CSS_THEME, 'weight' => 99]
                );
            } else {
                // Toon bijsnijden-UI met uitleg + vriendelijke foutmelding.
                $form['#validate'][]    = '_ozk_profielfoto_crop_fout_vertalen';
                $form['#after_build'][] = '_ozk_profielfoto_crop_uitleg_toevoegen';
            }

            // HEIC/HEIF accepteren: hang onze converter vooraan de upload-validators
            // van het fotoveld. Dit MOET hier (in form_alter, vóór form_builder),
            // omdat managed_file de upload afhandelt in zijn #value_callback en niet
            // in #process. Zie _ozk_profielfoto_validate_heic_naar_jpg().
            if (isset($form['field_profielfoto'])) {
                _ozk_profielfoto_heic_validator_inhaken($form['field_profielfoto']);
            }
        }
    }
}

/**
 * =======================================================================================
 * VALIDATE: _ozk_profielfoto_crop_fout_vertalen
 * =======================================================================================
 * Vervangt de technische manualcrop-validatiefout ("must have a cropping selection")
 * door een vriendelijke Nederlandse melding die de gebruiker uitlegt wat te doen.
 */
function _ozk_profielfoto_crop_fout_vertalen($form, &$form_state) {
    $fouten = form_get_errors();
    if (empty($fouten)) {
        return;
    }

    $bevat_crop_fout = FALSE;
    foreach ($fouten as $fout) {
        if (strpos($fout, 'must have a cropping selection') !== FALSE
            || strpos($fout, 'cropping selection') !== FALSE) {
            $bevat_crop_fout = TRUE;
            break;
        }
    }
    if (!$bevat_crop_fout) {
        return;
    }

    // Wis alle fouten en zet ze terug — met de crop-fout vervangen of onderdrukt.
    form_clear_error();
    $is_mobiel = _ozk_profielfoto_is_mobiel();

    // Drain ook de al-ge-queude sessie-berichten zodat de fout niet meer zichtbaar is.
    $sessie_fouten = drupal_get_messages('error', TRUE);
    $crop_patroon  = 'cropping selection';

    foreach ($fouten as $veld => $fout) {
        if (strpos($fout, $crop_patroon) !== FALSE) {
            if (!$is_mobiel) {
                form_set_error($veld, t('Foto nog niet bijgesneden — klik op de knop <strong>Bijsnijden</strong> onder de foto, sleep een vierkant gebied, en klik daarna op <strong>Opslaan</strong>.'));
            }
            // Op mobiel: stil weggooien, autocrop doet het server-side.
        } else {
            form_set_error($veld, $fout);
        }
    }

    // Zet sessie-foutberichten terug zonder de crop-meldingen.
    if (!empty($sessie_fouten['error'])) {
        foreach ($sessie_fouten['error'] as $bericht) {
            if (strpos($bericht, $crop_patroon) === FALSE) {
                drupal_set_message($bericht, 'error');
            }
        }
    }
}

/**
 * =======================================================================================
 * AFTER_BUILD: _ozk_profielfoto_crop_uitleg_toevoegen
 * =======================================================================================
 * Injecteert via inline JS een korte uitleg naast de bijsnijden-thumbnail, zodat de
 * gebruiker weet dat klikken op de miniatuur de cropper opent.
 */
function _ozk_profielfoto_crop_uitleg_toevoegen($form, &$form_state) {
    $js = <<<'JS'
(function ($) {
  Drupal.behaviors.ozkCropUitleg = {
    attach: function (context, settings) {
      // Voeg uitleg toe naast elke bijsnijden-thumbnail (eenmalig via .once()).
      $('.manualcrop-thumblist', context).once('ozk-crop-uitleg', function () {
        $(this).after(
          '<p class="ozk-crop-hint" style="margin-top:4px;font-size:0.9em;color:#555;">' +
          '<strong>Klik op het plaatje hierboven</strong> om de foto bij te snijden. ' +
          'Sleep daarna een vierkant gebied en klik op <em>Opslaan</em>.' +
          '</p>' +
          '<p class="ozk-crop-hint ozk-crop-hint--mobiel" style="margin-top:2px;font-size:0.85em;color:#888;">' +
          '&#128196; Tip: bijsnijden werkt het makkelijkst op een laptop of pc. Op een telefoon kan het wat lastiger zijn.' +
          '</p>'
        );
      });
    }
  };
}(jQuery));
JS;
    drupal_add_js($js, ['type' => 'inline', 'scope' => 'footer', 'weight' => 10]);
    return $form;
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_is_mobiel
 * =======================================================================================
 * Geeft TRUE als het huidige verzoek van een mobiel apparaat komt (telefoon of tablet).
 * Gebruikt de User-Agent — voldoende nauwkeurig voor de crop-beslissing.
 */
function _ozk_profielfoto_is_mobiel() {
    $ua = isset($_SERVER['HTTP_USER_AGENT']) ? $_SERVER['HTTP_USER_AGENT'] : '';
    return (bool) preg_match(
        '/Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile|Tablet/i',
        $ua
    );
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_autocrop_op_gezicht
 * =======================================================================================
 * Roept ozk-facedetect aan op de geüploade foto. Als er een gezicht gevonden wordt,
 * snijdt ImageMagick de foto vierkant bij rondom het gezicht (met padding voor hoofd +
 * schouders). Zo hoeft een mobiele gebruiker niet zelf te croppen via de cropper.
 *
 * Het bestand wordt IN PLACE overschreven: het fid blijft hetzelfde, alleen de
 * bestandsinhoud en afmetingen veranderen.
 */
function _ozk_profielfoto_autocrop_op_gezicht($entity) {
    $extdebug = 'ozk_profielfoto';
    $t_start  = microtime(TRUE);

    $veld = field_get_items('entityform', $entity, 'field_profielfoto');
    if (empty($veld[0]['fid'])) {
        return;
    }

    $bestand = file_load($veld[0]['fid']);
    if (!$bestand) {
        return;
    }

    $pad = drupal_realpath($bestand->uri);
    if (!$pad || !is_file($pad)) {
        watchdog($extdebug, 'autocrop: bestand niet gevonden op schijf: @uri', ['@uri' => $bestand->uri], WATCHDOG_WARNING);
        return;
    }

    // ------------------------------------------------------------------ 1. Gezicht detecteren
    // Verkleinde werkkopie voor snellere detectie (dlib schaal O(n²) mee met pixels).
    $script       = dirname(__FILE__) . '/bin/ozk-facedetect';
    $tmp_detect   = $pad . '.detect.jpg';
    $img_info_pre = getimagesize($pad);
    $schaal       = 1.0;
    $t_pre        = microtime(TRUE);
    if ($img_info_pre && max($img_info_pre[0], $img_info_pre[1]) > 800) {
        exec('magick ' . escapeshellarg($pad . '[0]') . " -resize '800x800>' " . escapeshellarg($tmp_detect));
        $tmp_info = getimagesize($tmp_detect);
        if ($tmp_info) {
            $schaal = $img_info_pre[0] / $tmp_info[0];
        }
        $detect_pad = $tmp_detect;
    } else {
        $detect_pad = $pad;
    }
    $t_preshrink = microtime(TRUE);
    watchdog($extdebug, 'TIMING pre-shrink: @ms ms (orig @bx@h → detectie op @dp)',
        ['@ms' => round(($t_preshrink - $t_pre) * 1000), '@b' => $img_info_pre[0] ?? '?',
         '@h' => $img_info_pre[1] ?? '?', '@dp' => basename($detect_pad)], WATCHDOG_DEBUG);

    $cmd_detect = escapeshellarg($script) . ' ' . escapeshellarg($detect_pad);
    $json_raw   = shell_exec($cmd_detect);
    $t_detect   = microtime(TRUE);
    watchdog($extdebug, 'TIMING facedetect: @ms ms', ['@ms' => round(($t_detect - $t_preshrink) * 1000)], WATCHDOG_DEBUG);

    if (isset($tmp_detect) && file_exists($tmp_detect)) {
        @unlink($tmp_detect);
    }
    $gezicht_raw = $json_raw ? json_decode($json_raw, TRUE) : NULL;
    // Coördinaten terugschalen naar originele afmetingen
    $gezicht = $gezicht_raw;
    if (!empty($gezicht_raw['found']) && $schaal > 1.0) {
        $gezicht = [
            'found'  => TRUE,
            'top'    => (int) round($gezicht_raw['top']    * $schaal),
            'right'  => (int) round($gezicht_raw['right']  * $schaal),
            'bottom' => (int) round($gezicht_raw['bottom'] * $schaal),
            'left'   => (int) round($gezicht_raw['left']   * $schaal),
        ];
    }

    if (empty($gezicht['found'])) {
        // Geen gezicht gevonden → val terug op gecentreerde vierkante crop (entropy-vrij).
        watchdog($extdebug, 'autocrop: geen gezicht gevonden in @f, val terug op midden-crop.', ['@f' => $bestand->filename], WATCHDOG_INFO);
        _ozk_profielfoto_autocrop_midden($pad);
        return;
    }

    watchdog($extdebug, 'autocrop: gezicht gevonden top=@t right=@r bottom=@b left=@l in @f', [
        '@t' => $gezicht['top'], '@r' => $gezicht['right'],
        '@b' => $gezicht['bottom'], '@l' => $gezicht['left'],
        '@f' => $bestand->filename,
    ], WATCHDOG_INFO);

    // ------------------------------------------------------------------ 2. Afmetingen origineel
    $img_info = getimagesize($pad);
    if (!$img_info) {
        watchdog($extdebug, 'autocrop: getimagesize mislukt voor @f', ['@f' => $pad], WATCHDOG_WARNING);
        return;
    }
    $img_breed  = $img_info[0];
    $img_hoogte = $img_info[1];

    // ------------------------------------------------------------------ 3. Vierkant rondom gezicht berekenen
    $gz_top    = $gezicht['top'];
    $gz_right  = $gezicht['right'];
    $gz_bottom = $gezicht['bottom'];
    $gz_left   = $gezicht['left'];

    $gz_breed  = $gz_right  - $gz_left;
    $gz_hoogte = $gz_bottom - $gz_top;
    $gz_cx     = (int) round(($gz_left + $gz_right)  / 2);
    $gz_cy     = (int) round(($gz_top  + $gz_bottom) / 2);

    // Padding: 2.5× de gezichtshoogte → ruimte voor kruin + schouders
    $zijde = (int) round(max($gz_breed, $gz_hoogte) * 2.5);
    $zijde = max($zijde, 100); // minimaal 100px

    // Gezichtscentrum op 42% van boven zodat kruin én kin goed passen
    $crop_top  = $gz_cy - (int) round($zijde * 0.42);
    $crop_left = $gz_cx - (int) round($zijde / 2);

    // Klem binnen de afbeeldingsgrenzen
    $crop_left = max(0, min($crop_left, $img_breed  - $zijde));
    $crop_top  = max(0, min($crop_top,  $img_hoogte - $zijde));
    $zijde     = min($zijde, $img_breed, $img_hoogte);

    // ------------------------------------------------------------------ 4. Crop + resize met ImageMagick
    // Max 400×400 zodat het bestand onder de 150KB cssinliner-embed-limiet blijft.
    $geometry = sprintf('%dx%d+%d+%d', $zijde, $zijde, $crop_left, $crop_top);
    $cmd_crop = sprintf(
        'magick %s -crop %s +repage -auto-orient -resize 400x400 -quality 85 %s',
        escapeshellarg($pad . '[0]'),
        escapeshellarg($geometry),
        escapeshellarg($pad)
    );
    exec($cmd_crop, $uitvoer, $rv);
    $t_crop = microtime(TRUE);
    watchdog($extdebug, 'TIMING ImageMagick crop+resize: @ms ms', ['@ms' => round(($t_crop - $t_detect) * 1000)], WATCHDOG_DEBUG);

    if ($rv !== 0) {
        watchdog($extdebug, 'autocrop: ImageMagick crop mislukt (rv=@rv) voor @f', ['@rv' => $rv, '@f' => $bestand->filename], WATCHDOG_ERROR);
        return;
    }

    // Bestandsgrootte in DB bijwerken na overschrijven
    $bestand->filesize = filesize($pad);
    file_save($bestand);

    watchdog($extdebug, 'autocrop: crop geslaagd (@g) voor @f — totaal @ms ms',
        ['@g' => $geometry, '@f' => $bestand->filename, '@ms' => round((microtime(TRUE) - $t_start) * 1000)], WATCHDOG_INFO);
}

/**
 * Fallback: vierkante crop gecentreerd in de afbeelding (als ozk-facedetect geen gezicht vindt).
 */
function _ozk_profielfoto_autocrop_midden($pad) {
    $cmd = sprintf(
        'magick %s -gravity Center -extent "%%[fx:min(w,h)]x%%[fx:min(w,h)]" +repage -resize 400x400 -quality 85 %s',
        escapeshellarg($pad . '[0]'),
        escapeshellarg($pad)
    );
    exec($cmd, $uitvoer, $rv);
    if ($rv !== 0) {
        watchdog('ozk_profielfoto', 'autocrop_midden: ImageMagick mislukt (rv=@rv)', ['@rv' => $rv], WATCHDOG_ERROR);
    }
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_heic_validator_inhaken
 * =======================================================================================
 * Loopt recursief door het field_profielfoto-formulierfragment en hangt op ELK element
 * met #upload_validators onze HEIC->JPEG-converter VOORAAN, zodat die draait vóór de
 * standaard image-validators (file_validate_is_image / file_validate_extensions).
 * Tevens staan we .heic/.heif toe in de extensie-check (defensief; na conversie heet
 * het bestand toch .jpg).
 */
function _ozk_profielfoto_heic_validator_inhaken(&$element) {
    if (!is_array($element)) {
        return;
    }

    if (isset($element['#upload_validators']) && is_array($element['#upload_validators'])) {
        // 1. Extensie toestaan (defensief).
        if (!empty($element['#upload_validators']['file_validate_extensions'][0])
            && strpos($element['#upload_validators']['file_validate_extensions'][0], 'heic') === FALSE) {
            $element['#upload_validators']['file_validate_extensions'][0] .= ' heic heif';
        }
        // 2. Converter VOORAAN (array-unie behoudt volgorde: links eerst).
        if (!isset($element['#upload_validators']['_ozk_profielfoto_validate_heic_naar_jpg'])) {
            $element['#upload_validators'] =
                ['_ozk_profielfoto_validate_heic_naar_jpg' => []]
                + $element['#upload_validators'];
        }
    }

    // Recursief door de child-elementen (taal-container + delta's).
    foreach (element_children($element) as $key) {
        _ozk_profielfoto_heic_validator_inhaken($element[$key]);
    }
}

/**
 * =======================================================================================
 * UPLOAD-VALIDATOR: _ozk_profielfoto_validate_heic_naar_jpg
 * =======================================================================================
 * Zet een geüploade HEIC/HEIF om naar JPEG. Draait als EERSTE upload-validator, terwijl
 * $file->uri nog naar de geüploade tmp-file wijst. We overschrijven die tmp-file IN PLACE
 * met de JPEG-bytes, want file_save_upload() verplaatst straks letterlijk
 * $_FILES[...]['tmp_name'] (niet $file->uri) naar de bestemming. Daarna corrigeren we
 * $file->filename naar .jpg, zodat de bestemming, de extensie-check en de latere
 * image-validators (GD/getimagesize) allemaal een geldige JPEG zien.
 *
 * Achtergrond: Drupals image_get_info() leest afmetingen via getimagesize() (ook met de
 * ImageMagick-toolkit, want image_imagemagick_get_info() gebruikt getimagesize()), en dat
 * kan HEIC niet. Daarom converteren we hier zelf met de 'magick'-binary (libheif: rw+).
 *
 * @param stdClass $file  Het in-validatie zijnde bestand (uri = geüploade tmp-file).
 * @return array          Lege array bij succes; foutmeldingen voor file_validate() bij falen.
 */
function _ozk_profielfoto_validate_heic_naar_jpg(stdClass $file) {
    $extdebug = 'ozk_profielfoto';
    $errors   = [];

    // Fysiek pad naar het (tmp-)bestand bepalen. tmp-uploads zijn vaak een kaal abs. pad.
    $pad = drupal_realpath($file->uri);
    if (empty($pad) || !is_file($pad)) {
        $pad = $file->uri;
    }
    if (!is_file($pad)) {
        return $errors;
    }

    // HEIC/HEIF herkennen: ISO-BMFF 'ftyp'-merk in de header, of de extensie.
    $kop     = (string) @file_get_contents($pad, FALSE, NULL, 0, 32);
    $is_heic = (bool) preg_match('/ftyp(heic|heix|hevc|heim|heis|hevm|hevs|mif1|msf1)/', $kop)
            || (bool) preg_match('/\.(heic|heif)$/i', $file->filename);
    if (!$is_heic) {
        return $errors; // geen HEIC -> niets doen, normale validatie loopt door
    }

    // Converteren: eerste frame, oriëntatie corrigeren, naar sRGB, metadata strippen.
    $tmp_jpg = $pad . '.ozkconv.jpg';
    $cmd     = sprintf('magick %s -auto-orient -colorspace sRGB -strip -quality 88 %s',
                       escapeshellarg($pad . '[0]'), escapeshellarg($tmp_jpg));
    exec($cmd, $uitvoer, $rv);

    if ($rv !== 0 || !is_file($tmp_jpg) || filesize($tmp_jpg) === 0) {
        @unlink($tmp_jpg);
        watchdog($extdebug, 'HEIC-conversie mislukt voor %f (rv=@rv).',
                 ['%f' => $file->filename, '@rv' => $rv], WATCHDOG_ERROR);
        $errors[] = t('Deze foto (HEIC) kon niet worden verwerkt. Sla hem op als JPG en probeer het opnieuw.');
        return $errors;
    }

    // tmp-upload IN PLACE vervangen door de JPEG (zelfde pad blijft een geldige upload).
    if (!@rename($tmp_jpg, $pad)) {
        @copy($tmp_jpg, $pad);
        @unlink($tmp_jpg);
    }

    // Naam/mime gelijktrekken zodat bestemming + vervolgvalidators .jpg zien.
    $file->filename = preg_replace('/\.(heic|heif)$/i', '.jpg', $file->filename);
    if (!preg_match('/\.jpe?g$/i', $file->filename)) {
        $file->filename .= '.jpg';
    }
    $file->filemime = 'image/jpeg';
    if (isset($file->name)) {
        $file->name = $file->filename;
    }

    watchdog($extdebug, 'HEIC/HEIF omgezet naar JPEG: %f', ['%f' => $file->filename], WATCHDOG_INFO);
    return $errors;
}

/**
 * Geforceerde redirect handler.
 */
function _ozk_profielfoto_profielfoto_redirect_force($form, &$form_state) {
    if (isset($_GET['destination'])) {
        // DEBUG: Log als er een destination wordt gedwarsboomd
        watchdog('ozk_profielfoto', "Destination '@dest' verwijderd voor redirect.", ['@dest' => $_GET['destination']], WATCHDOG_DEBUG);
        unset($_GET['destination']);
    }
    
    $form_state['redirect'] = 'account';
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_sync_profielfoto_naar_civicrm
 * =======================================================================================
 * Haalt de geüploade foto uit de Entityform en pusht de gecropte URL naar CiviCRM.
 * De square_profielfoto image style past de manualcrop-selectie van de gebruiker toe.
 * Dit triggert automatisch de intake_civicrm_pre hook in intake.php, die de
 * datums (custom_2253 en custom_1798) perfect en zonder timing-conflicten beheert.
 */
function _ozk_profielfoto_sync_profielfoto_naar_civicrm($entity) {
	$extdebug				= 'intake.profielfoto';
	$t_sync_start			= microtime(TRUE);

	// 1. Controleer of er een bestand is geüpload
	$field_data				= field_get_items('entityform', $entity, 'field_profielfoto');

	if (!$field_data || empty($field_data[0]['uri'])) {
		return;
	}

	// 2. Gebruik de square_profielfoto styled URL voor CiviCRM zodat de manualcrop
	//    selectie van de gebruiker ook in het CiviCRM-profielfoto-veld terecht komt.
	//    Op mobiel is de file al vierkant bijgesneden door autocrop; gebruik dan de
	//    directe file-URL zodat er geen mislukte manualcrop-derivative wordt aangevraagd.
	$drupal_uri             = $field_data[0]['uri'];
	if (!defined('OZK_PROFIELFOTO_AUTOCROP_ALTIJD')) {
		define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', TRUE);
	}
	if (OZK_PROFIELFOTO_AUTOCROP_ALTIJD || _ozk_profielfoto_is_mobiel()) {
		// Bestand is al vierkant bijgesneden door autocrop.
		// Sla de directe bestandsURL op — de CiviCRM Views handler past zelf de
		// gewenste image style toe per view display (square_0260, square_0320, etc.).
		$image_url = file_create_url($drupal_uri);
	} else {
		$image_url = image_style_url('square_profielfoto', $drupal_uri);
	}
	_ozk_profielfoto_push_image_url_naar_civicrm($entity->uid, $image_url, $drupal_uri);
}

/**
 * =======================================================================================
 * HELPER (testbare seam): _ozk_profielfoto_push_image_url_naar_civicrm
 * =======================================================================================
 * Pusht een absolute image-URL naar CiviCRM voor een gegeven Drupal-UID en stuurt de
 * notificatiemail. Afgesplitst van _ozk_profielfoto_sync_profielfoto_naar_civicrm() zodat
 * e2e-tests de volledige sync -> intake-pre-hook -> DB-keten kunnen draaien zonder de
 * Drupal-only field_get_items()/file_create_url() te stubben (die in de e2e-boot niet te
 * overschrijven zijn omdat Drupal's eigen versie al geladen is).
 *
 * @param string      $image_url   Gecropte absolute URL (square_profielfoto style) → naar CiviCRM
 * @param string|null $drupal_uri  Originele Drupal URI (public://...) voor mail-thumbnail generatie
 */
function _ozk_profielfoto_push_image_url_naar_civicrm($uid, $image_url, $drupal_uri = NULL) {
	$extdebug				= 'intake.profielfoto';

	if (!civicrm_initialize()) {
		return;
	}

	$contact_id				= CRM_Core_BAO_UFMatch::getContactId($uid);

	if ($contact_id) {
		
		wachthond($extdebug, 2, "########################################################################");
		wachthond($extdebug, 1, "### DRUPAL SYNC: PROFIELFOTO NAAR CIVICRM PUSHEN",		"[CID: $contact_id]");
		wachthond($extdebug, 2, "########################################################################");

		wachthond($extdebug, 3, 'image_url direct SQL', $image_url);

		try {
			// 3. Directe SQL voor image_URL — bypast delta/stgave/training hook-stack (~12-19s).
			//    image_URL is geen bedrijfslogica-veld; hooks hoeven hier niet te vuren.
			CRM_Core_DAO::executeQuery(
				'UPDATE civicrm_contact SET image_URL = %1 WHERE id = %2',
				[1 => [$image_url, 'String'], 2 => [$contact_id, 'Integer']]
			);
			wachthond($extdebug, 3, 'image_url bijgewerkt via SQL', $contact_id);

			// 3b. Foto datum + status direct via SQL (base_api_wrapper → Contact.update triggert
			//     anders de volledige hook-stack van ~20s; civicrm_value_intake_181 UPSERT).
			// OZK_PROFIELFOTO_AUTOCROP_ALTIJD = TRUE: autocrop garandeert altijd een vierkant
			// resultaat → direct status 2 ('vierkant') wegschrijven, geen recompute nodig.
			$new_fot_update = date('YmdHis');
			CRM_Core_DAO::executeQuery(
				'INSERT INTO civicrm_value_intake_181 (entity_id, fot_update_2253, fot_status_1798)
				 VALUES (%1, %2, 2)
				 ON DUPLICATE KEY UPDATE fot_update_2253 = %2, fot_status_1798 = 2',
				[1 => [$contact_id, 'Integer'], 2 => [$new_fot_update, 'String']]
			);
			wachthond($extdebug, 3, 'fot_update + fot_status direct SQL', $new_fot_update);
			
			watchdog('ozk_profielfoto', "Profielfoto URL succesvol gesynchroniseerd voor CID: $contact_id", NULL, WATCHDOG_INFO);

			// 5. E-mail notificatie versturen (met Ymd_His timestamp)
			// ... binnen de _ozk_profielfoto_sync_profielfoto_naar_civicrm functie ...

			// Displayname ophalen via APIv4
			$params_contact_naam = [
				'checkPermissions' => FALSE,
				'debug'            => FALSE,
				'select'           => ['display_name'],
				'where'            => [['id', '=', $contact_id]],
			];
			wachthond($extdebug, 7, 'params_contact_naam',  $params_contact_naam);
			$result_contact_naam = civicrm_api4('Contact', 'get', $params_contact_naam);
			wachthond($extdebug, 9, 'result_contact_naam',  $result_contact_naam);
			$display_name        = $result_contact_naam->first()['display_name'] ?? '(onbekend)';

			// Ditjaar kampkort en kampfunctie via base_find_allpart
			$allpart_array       = function_exists('base_find_allpart') ? base_find_allpart($contact_id) : FALSE;
			$ditjaar_kampkort    = $allpart_array ? ($allpart_array['result_allpart_one_kampkort']    ?? NULL) : NULL;
			$ditjaar_kampfunctie = $allpart_array ? ($allpart_array['result_allpart_one_kampfunctie'] ?? NULL) : NULL;
			$ditjaar_event_id    = $allpart_array ? ($allpart_array['result_allpart_one_event_id']    ?? NULL) : NULL;
			wachthond($extdebug, 3, 'ditjaar_kampkort',     $ditjaar_kampkort);
			wachthond($extdebug, 3, 'ditjaar_kampfunctie',  $ditjaar_kampfunctie);

			// Haal event-titel op als kamplang (lange naam voor indiener-mail).
			$ditjaar_kampnaam = NULL;
			if ($ditjaar_event_id) {
				$params_event = [
					'checkPermissions' => FALSE,
					'select'           => ['title'],
					'where'            => [['id', '=', $ditjaar_event_id]],
				];
				wachthond($extdebug, 7, 'params_event', $params_event);
				$result_event     = civicrm_api4('Event', 'get', $params_event);
				wachthond($extdebug, 9, 'result_event', $result_event);
				$ditjaar_kampnaam = $result_event->first()['title'] ?? NULL;
			}
			wachthond($extdebug, 3, 'ditjaar_kampnaam', $ditjaar_kampnaam);

			// Pre-genereer alle benodigde image-style derivatives zodat de tokens
			// in mails direct werken zonder on-demand generatie door Drupal.
			if ($drupal_uri) {
				foreach (['square_profielfoto', 'square_0260', 'square_0260_naam'] as $_style_name) {
					$_style_def = image_style_load($_style_name);
					if (!$_style_def) continue;
					$_style_uri = image_style_path($_style_name, $drupal_uri);
					if (!file_exists(drupal_realpath($_style_uri))) {
						image_style_create_derivative($_style_def, $drupal_uri, $_style_uri);
						wachthond($extdebug, 3, 'derivative aangemaakt', $_style_name);
					}
				}
			}

			// Bereken square_0260 URL voor de polaroid in de mail.
			$sq0260_url = $drupal_uri ? image_style_url('square_0260', $drupal_uri) : $image_url;

			$tpl_params = [
				'fotoedit'      => 'https://www.onvergetelijk.nl/profielfoto',
				'fotolink'      => $sq0260_url,
				'user_kamplang' => $ditjaar_kampnaam ?: $ditjaar_kampkort ?: 'je kamp',
				'ozkweburl'     => 'https://www.onvergetelijk.nl',
				'user_cid'      => $contact_id,
			];

			wachthond($extdebug, 3, 'TIMING sync tot e-mail: ' . round((microtime(TRUE) - $t_sync_start) * 1000) . ' ms', '');

			// Beheerder-notificatie (zelfde template, apart onderwerp).
			$t_mail1 = microtime(TRUE);
			try {
				\CRM_Core_BAO_MessageTemplate::sendTemplate([
					'messageTemplateID' => 608,
					'contactId'         => $contact_id,
					'toEmail'           => 'richard.van.oosterhout@gmail.com',
					'toName'            => 'Webteam OZK',
					'from'              => 'OZK <info@onvergetelijk.nl>',
					'subject'           => '[CRM] Profielfoto update - ' . date('Ymd_His'),
					'tplParams'         => $tpl_params,
				]);
				wachthond($extdebug, 3, "TIMING mail beheerder: " . round((microtime(TRUE) - $t_mail1) * 1000) . " ms", "[CRM]");
				wachthond($extdebug, 3, "E-mail notificatie verzonden naar beheerder", "[CRM]");
			} catch (\Throwable $sendEx) {
				wachthond($extdebug, 1, "sendTemplate beheerder mislukt", $sendEx->getMessage());
			}

			// Indiener-bevestiging (zelfde template, naar primair e-mailadres van de contact).
			$t_mail2 = microtime(TRUE);
			try {
				\CRM_Core_BAO_MessageTemplate::sendTemplate([
					'messageTemplateID' => 608,
					'contactId'         => $contact_id,
					'from'              => 'OZK <info@onvergetelijk.nl>',
					'tplParams'         => $tpl_params,
				]);
				wachthond($extdebug, 3, "TIMING mail indiener: " . round((microtime(TRUE) - $t_mail2) * 1000) . " ms", $contact_id);
				wachthond($extdebug, 3, "E-mail bevestiging verzonden naar indiener CID", $contact_id);
			} catch (\Throwable $sendEx) {
				wachthond($extdebug, 1, "sendTemplate indiener mislukt", $sendEx->getMessage());
			}

		} catch (\Exception $e) {
			$error_msg			= $e->getMessage();
			wachthond($extdebug, 1, "FATAAL: Fout bij pushen profielfoto naar CiviCRM",	$error_msg);
			watchdog('ozk_profielfoto', "Fout bij pushen profielfoto: $error_msg", NULL, WATCHDOG_ERROR);
		}
	} else {
		watchdog('ozk_profielfoto', "Geen CiviCRM contact gevonden voor Drupal UID: $uid", NULL, WATCHDOG_WARNING);
	}
}


