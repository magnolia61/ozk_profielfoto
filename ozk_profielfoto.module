<?php

/**
 * Implements hook_entity_insert().
 * Vervangt de Rule: "Entityform Profielfoto Upload"
 */
function ozk_profielfoto_entity_insert($entity, $type) {
    if ($type !== 'entityform' || !in_array($entity->type, ['profielfoto', 'profielfoto_sq'])) {
        return;
    }
    $veld = field_get_items('entityform', $entity, 'field_profielfoto');
    if (empty($veld[0]['fid'])) {
        return;
    }
    $bestand = file_load($veld[0]['fid']);
    if (!$bestand) {
        return;
    }
    _ozk_profielfoto_plan_achtergrond([
        'uid'         => $entity->uid,
        'contact_id'  => _ozk_profielfoto_resolve_contact_id($entity->uid),
        'fid'         => (int) $bestand->fid,
        'drupal_uri'  => $bestand->uri,
        'upload_bron' => 'entityform',
    ]);
}

/**
 * Implements hook_entity_update().
 * Vervangt de Rule: "Entityform Profielfoto Update"
 */
function ozk_profielfoto_entity_update($entity, $type) {
    if ($type !== 'entityform' || !in_array($entity->type, ['profielfoto', 'profielfoto_sq'])) {
        return;
    }
    $veld = field_get_items('entityform', $entity, 'field_profielfoto');
    if (empty($veld[0]['fid'])) {
        return;
    }
    $bestand = file_load($veld[0]['fid']);
    if (!$bestand) {
        return;
    }
    _ozk_profielfoto_plan_achtergrond([
        'uid'         => $entity->uid,
        'contact_id'  => _ozk_profielfoto_resolve_contact_id($entity->uid),
        'fid'         => (int) $bestand->fid,
        'drupal_uri'  => $bestand->uri,
        'upload_bron' => 'entityform',
    ]);
}

/**
 * Lost het CiviCRM contact_id op uit een Drupal UID, ín de hoofdrequest waar
 * CiviCRM gegarandeerd actief is. Geeft NULL terug als het niet lukt; de shutdown
 * valt dan terug op een eigen lookup.
 */
function _ozk_profielfoto_resolve_contact_id($uid) {
    if (!$uid || !civicrm_initialize()) {
        return NULL;
    }
    $cid = CRM_Core_BAO_UFMatch::getContactId($uid);
    return $cid ? (int) $cid : NULL;
}

/**
 * Implements hook_webform_submission_insert().
 * Koppelt autocrop + derivative-generatie aan uploads via webform node 608 (Profielfoto).
 */
function ozk_profielfoto_webform_submission_insert($node, $submission) {
    _ozk_profielfoto_webform_achtergrond_plannen($node, $submission);
}

/**
 * Implements hook_webform_submission_update().
 */
function ozk_profielfoto_webform_submission_update($node, $submission) {
    _ozk_profielfoto_webform_achtergrond_plannen($node, $submission);
}

/**
 * Haalt fid/uri op uit een webform-submission en plant achtergrondverwerking.
 */
function _ozk_profielfoto_webform_achtergrond_plannen($node, $submission) {
    if ($node->nid != 608) {
        return;
    }
    // Zoek de cid op via form_key zodat de code niet breekt als het component
    // ooit opnieuw wordt aangemaakt en een ander auto-increment cid krijgt.
    $cid = NULL;
    foreach ($node->webform['components'] as $component) {
        if ($component['form_key'] === 'civicrm_1_contact_1_contact_image_URL') {
            $cid = (int) $component['cid'];
            break;
        }
    }
    $fid = ($cid && !empty($submission->data[$cid][0])) ? (int) $submission->data[$cid][0] : 0;
    if (!$fid) {
        watchdog('ozk_profielfoto', 'webform 608: geen fid gevonden (form_key civicrm_1_contact_1_contact_image_URL, cid=@cid)', ['@cid' => $cid ?? '?'], WATCHDOG_WARNING);
        return;
    }
    $bestand = file_load($fid);
    if (!$bestand) {
        watchdog('ozk_profielfoto', 'webform 608: file_load(@fid) mislukt', ['@fid' => $fid], WATCHDOG_WARNING);
        return;
    }
    // Het contact_id zit al in de submission (CiviCRM-webform-integratie). Pak het
    // hier op zodat de shutdown geen UFMatch-lookup meer hoeft te doen. Belangrijk:
    // bij de anonieme checksumlink-route is $submission->uid = 0, dus een
    // getContactId($uid) in de shutdown zou daar niets vinden.
    $contact_id = !empty($submission->civicrm['contact'][1]['id'])
        ? (int) $submission->civicrm['contact'][1]['id']
        : NULL;
    _ozk_profielfoto_plan_achtergrond([
        'uid'         => $submission->uid,
        'contact_id'  => $contact_id,
        'fid'         => $fid,
        'drupal_uri'  => $bestand->uri,
        'upload_bron' => 'webform',
    ]);
}

/**
 * Registreert de zware fotoverwerking als shutdown-functie zodat de browser
 * de redirect ontvangt vóór facedetect/crop/derivatives/mails worden uitgevoerd.
 *
 * fastcgi_finish_request() sluit de HTTP-verbinding; PHP-FPM draait daarna door.
 * Zonder die functie (mod_php) valt het terug op synchrone uitvoering in de shutdown.
 *
 * @param array $params  ['uid', 'contact_id', 'fid', 'drupal_uri', 'upload_bron']
 */
function _ozk_profielfoto_plan_achtergrond(array $params) {
    // Voorkom dubbele registratie als zowel insert als update vuren (Drupal-edge case).
    static $_gepland = [];
    $sleutel = $params['fid'] . ':' . $params['uid'];
    if (!empty($_gepland[$sleutel])) {
        return;
    }
    $_gepland[$sleutel] = TRUE;

    watchdog('ozk_profielfoto', 'Achtergrondverwerking ingepland voor UID @uid, FID @fid via @bron.',
        ['@uid' => $params['uid'], '@fid' => $params['fid'], '@bron' => $params['upload_bron']], WATCHDOG_INFO);

    drupal_register_shutdown_function('_ozk_profielfoto_verwerk_achtergrond', $params);
}

/**
 * Voert de zware fotoverwerking uit ná het verzenden van de HTTP-response.
 *
 * Stappen (in volgorde, met TIMING-logging per stap):
 *   0. Verbinding sluiten via fastcgi_finish_request() zodat browser klaar is
 *   1. Bestand laden + realpath controleren
 *   2. Contact.update image_URL
 *   3. fot_status=1 ("in verwerking") schrijven — zichtbaar voor admin/retry-cron
 *   4. Gedeelde verwerking: autocrop → derivatives → fot_status=2 → mails
 *
 * Noot: de webform-route schreef vroeger een public-master kopie (private→public).
 * Dat is niet meer nodig: webform component 7 staat op scheme=public, bestanden
 * landen direct in public://profielfotos/.
 *
 * @param array $params  ['uid', 'contact_id', 'fid', 'drupal_uri', 'upload_bron']
 */
function _ozk_profielfoto_verwerk_achtergrond(array $params) {
    $extdebug  = 'ozk_profielfoto';
    $t_start   = microtime(TRUE);
    $_tp = function($label, $t0) use ($extdebug, $t_start) {
        $ms_stap   = round((microtime(TRUE) - $t0)    * 1000);
        $ms_totaal = round((microtime(TRUE) - $t_start) * 1000);
        watchdog($extdebug, "TIMING achtergrond [@ms_totaalms] $label: @ms_stap ms",
            ['@ms_totaal' => $ms_totaal, '@ms_stap' => $ms_stap], WATCHDOG_DEBUG);
        return microtime(TRUE);
    };

    $uid         = $params['uid'];
    $contact_id  = !empty($params['contact_id']) ? (int) $params['contact_id'] : NULL;
    $fid         = $params['fid'];
    $drupal_uri  = $params['drupal_uri'];
    $upload_bron = $params['upload_bron'];

    // ── 0. Verbinding sluiten ────────────────────────────────────────────────
    // fastcgi_finish_request() stuurt de HTTP-response naar de browser en laat
    // PHP-FPM daarna doordraaien. Zonder php-fpm (mod_php) is dit een no-op;
    // de verwerking loopt dan gewoon synchroon in de shutdown (langzamer voor
    // de gebruiker, maar correct). set_time_limit(0) voorkomt dat een lange
    // facedetect-run afgebroken wordt door max_execution_time.
    if (function_exists('fastcgi_finish_request')) {
        fastcgi_finish_request();
    }
    set_time_limit(0);

    $t_stap = microtime(TRUE);
    watchdog($extdebug, 'Achtergrondverwerking START voor UID @uid FID @fid via @bron.',
        ['@uid' => $uid, '@fid' => $fid, '@bron' => $upload_bron], WATCHDOG_INFO);

    // ── 1. Bestand laden ─────────────────────────────────────────────────────
    $bestand = file_load($fid);
    if (!$bestand) {
        watchdog($extdebug, 'achtergrond: file_load(@fid) mislukt — stop.', ['@fid' => $fid], WATCHDOG_ERROR);
        return;
    }
    $pad = drupal_realpath($bestand->uri);
    if (!$pad || !is_file($pad)) {
        watchdog($extdebug, 'achtergrond: bestand niet op schijf: @uri — stop.', ['@uri' => $bestand->uri], WATCHDOG_ERROR);
        return;
    }
    $t_stap = $_tp('1. file_load + realpath', $t_stap);

    // ── 2. Contact.update image_URL ──────────────────────────────────────────
    if (!civicrm_initialize()) {
        watchdog($extdebug, 'achtergrond: civicrm_initialize mislukt — stop.', [], WATCHDOG_ERROR);
        return;
    }
    // Het contact_id is in de hoofdrequest al opgelost en meegegeven. Alleen als
    // dat (bij uitzondering) niet lukte, vallen we hier terug op een UFMatch-lookup
    // — die faalt voor de anonieme checksumlink-route (uid=0), vandaar de voorkeur
    // voor de meegegeven waarde.
    if (!$contact_id) {
        $contact_id = CRM_Core_BAO_UFMatch::getContactId($uid);
    }
    if (!$contact_id) {
        watchdog($extdebug, 'achtergrond: geen contact_id (uid=@u, niet meegegeven) — stop.', ['@u' => $uid], WATCHDOG_ERROR);
        return;
    }
    $image_url = file_create_url($drupal_uri);
    $params_contact_update = [
        'checkPermissions' => FALSE,
        'debug'            => FALSE,
        'where'            => [['id', '=', $contact_id]],
        'values'           => ['image_URL' => $image_url],
    ];
    wachthond($extdebug, 7, 'params_contact_update', $params_contact_update);
    $result_contact_update = civicrm_api4('Contact', 'update', $params_contact_update);
    wachthond($extdebug, 9, 'result_contact_update', $result_contact_update);
    $t_stap = $_tp('2. Contact.update image_URL', $t_stap);

    // ── 3. fot_status=1 ("in verwerking") ────────────────────────────────────
    // Schrijf direct na de contact-update zodat de retry-cron weet dat deze
    // job gestart is. verwerk_na_move schrijft fot_status=2 als alles klaar is.
    // ON DUPLICATE KEY zodat het veld ook aangemaakt wordt als er nog geen rij is.
    db_query(
        "INSERT INTO {civicrm_value_intake_181} (entity_id, fot_status_1798, fot_update_2253)
         VALUES (:cid, 1, NOW())
         ON DUPLICATE KEY UPDATE fot_status_1798 = 1, fot_update_2253 = NOW()",
        [':cid' => $contact_id]
    );
    $t_stap = $_tp('3. fot_status=1 schrijven', $t_stap);

    // ── 4. Gedeelde verwerking (autocrop → derivatives → fot_status=2 → mails) ─
    _ozk_profielfoto_verwerk_na_move($drupal_uri, $contact_id, $upload_bron);

    $ms_totaal = round((microtime(TRUE) - $t_start) * 1000);
    watchdog($extdebug, 'Achtergrondverwerking KLAAR in @ms ms voor UID @uid via @bron.',
        ['@ms' => $ms_totaal, '@uid' => $uid, '@bron' => $upload_bron], WATCHDOG_INFO);
}

/**
 * =======================================================================================
 * KERN: _ozk_profielfoto_verwerk_na_move
 * =======================================================================================
 * Canonieke post-move verwerking: autocrop → upscale → derivatives → fot_status → mails.
 * Gedeeld door alle drie uploadroutes (entityform, webform, crm-profiel).
 *
 * Wordt aangeroepen vanuit _ozk_profielfoto_verwerk_achtergrond() (entityform/webform)
 * of rechtstreeks als shutdown function vanuit intake.php (crm-profiel route).
 *
 * @param string $dst_uri     Drupal URI van het bestand in zijn definitieve locatie
 *                            (public://profielfotos/...). Wordt in-place gecropd.
 * @param int    $contact_id  CiviCRM contact ID.
 * @param string $upload_bron 'entityform' | 'webform' | 'crm-profiel'
 */
function _ozk_profielfoto_verwerk_na_move($dst_uri, $contact_id, $upload_bron) {
    $extdebug = 'ozk_profielfoto';
    $t_start  = microtime(TRUE);
    $_tp = function($label, $t0) use ($extdebug, $t_start) {
        $ms_stap   = round((microtime(TRUE) - $t0)    * 1000);
        $ms_totaal = round((microtime(TRUE) - $t_start) * 1000);
        watchdog($extdebug, "TIMING na_move    [@ms_totaalms] $label: @ms_stap ms",
            ['@ms_totaal' => $ms_totaal, '@ms_stap' => $ms_stap], WATCHDOG_DEBUG);
        return microtime(TRUE);
    };

    if (!civicrm_initialize()) {
        watchdog($extdebug, 'verwerk_na_move: civicrm_initialize mislukt — stop.', [], WATCHDOG_ERROR);
        return;
    }
    $pad = drupal_realpath($dst_uri);
    if (!$pad || !is_file($pad)) {
        watchdog($extdebug, 'verwerk_na_move: bestand niet op schijf: @uri — stop.', ['@uri' => $dst_uri], WATCHDOG_ERROR);
        return;
    }
    watchdog($extdebug, 'verwerk_na_move START CID @cid via @bron: @f',
        ['@cid' => $contact_id, '@bron' => $upload_bron, '@f' => basename($pad)], WATCHDOG_INFO);

    // ── 0b. Hash van de RUWE upload (vóór de crop hieronder) ──────────────────
    // Hiermee bepalen we straks of dit écht een nieuwe foto is (inhoud verschilt van
    // de vorige upload van dit contact). Alleen dan gaat de 608-mail naar de
    // deelnemer/ouder. Zo voorkomen we een 608 bij re-processing of bij het opnieuw
    // insturen van dezelfde foto. Per contact bewaard in een sidecar-bestand.
    $upload_hash = @md5_file($pad) ?: '';

    $t_stap = microtime(TRUE);

    // ── 1. Vergelijkmodus (tijdelijk, opt-in) — draait op origineel vóór crop ─
    if (function_exists('variable_get') && variable_get('ozk_profielfoto_vergelijk', FALSE)) {
        module_load_include('inc', 'ozk_profielfoto', 'ozk_profielfoto.vergelijk');
        if (function_exists('_ozk_profielfoto_vergelijk_varianten')) {
            _ozk_profielfoto_vergelijk_varianten($pad, ['contact_id' => (int) $contact_id]);
        }
        $t_stap = $_tp('1. vergelijk-modus', $t_stap);
    }

    // ── 2. Facedetect + autocrop (in-place op $pad) ───────────────────────────
    if (!defined('OZK_PROFIELFOTO_AUTOCROP_ALTIJD')) {
        define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', TRUE);
    }
    _ozk_profielfoto_autocrop_op_pad($pad);
    $t_stap = $_tp('2. facedetect + autocrop', $t_stap);

    // ── 3. Upscale naar ≥2160px tbv image_style_create_derivative ────────────
    $_img = @getimagesize($pad);
    if ($_img && max($_img[0], $_img[1]) < 2160) {
        exec('magick ' . escapeshellarg($pad . '[0]') . ' -resize 2160x2160 -quality 92 ' . escapeshellarg($pad));
        wachthond($extdebug, 3, 'bron opgeschaald naar 2160px', basename($pad));
    }
    $t_stap = $_tp('3. upscale naar 2160px', $t_stap);

    // ── 4. Manualcrop-coördinaten meeschalen indien bron vergroot is ──────────
    $_fid_mc = db_query("SELECT fid FROM {file_managed} WHERE uri = :uri", [':uri' => $dst_uri])->fetchField();
    if ($_fid_mc && $_img) {
        $_new_img = @getimagesize($pad);
        if ($_new_img && $_new_img[0] !== $_img[0]) {
            $_sx = $_new_img[0] / $_img[0];
            $_sy = $_new_img[1] / $_img[1];
            db_query(
                "UPDATE {manualcrop} SET x=ROUND(x*:sx), y=ROUND(y*:sy), width=ROUND(width*:sx), height=ROUND(height*:sy) WHERE fid=:fid",
                [':sx' => $_sx, ':sy' => $_sy, ':fid' => $_fid_mc]
            );
            wachthond($extdebug, 3, 'manualcrop coords meeopgeschaald', "sx={$_sx} sy={$_sy}");
        }
        // Vangrail: coords die buiten brondimensies vallen terugschalen.
        $_src_now = @getimagesize($pad);
        if ($_src_now) {
            $_mc_row = db_query(
                "SELECT x, y, width, height FROM {manualcrop} WHERE fid=:fid AND style_name='square_profielfoto'",
                [':fid' => $_fid_mc]
            )->fetchAssoc();
            if ($_mc_row) {
                $_mc_right  = $_mc_row['x'] + $_mc_row['width'];
                $_mc_bottom = $_mc_row['y'] + $_mc_row['height'];
                if ($_mc_right > $_src_now[0] || $_mc_bottom > $_src_now[1]) {
                    $_scale = min($_src_now[0] / max($_mc_right, 1), $_src_now[1] / max($_mc_bottom, 1));
                    db_update('manualcrop')
                        ->fields([
                            'x'      => (int) round($_mc_row['x']      * $_scale),
                            'y'      => (int) round($_mc_row['y']      * $_scale),
                            'width'  => (int) round($_mc_row['width']  * $_scale),
                            'height' => (int) round($_mc_row['height'] * $_scale),
                        ])
                        ->condition('fid',        $_fid_mc)
                        ->condition('style_name', 'square_profielfoto')
                        ->execute();
                    wachthond($extdebug, 3, 'manualcrop coords teruggeschaald', $_mc_row);
                }
            }
        }
    }
    $t_stap = $_tp('4. manualcrop schalen', $t_stap);

    // ── 5. Voornaam voor polaroid ─────────────────────────────────────────────
    $_voornaam = ucwords(CRM_Core_DAO::singleValueQuery(
        'SELECT first_name FROM civicrm_contact WHERE id = %1',
        [1 => [(int) $contact_id, 'Integer']]
    ) ?: '');

    // ── 6. Derivatives (4 image-styles) ──────────────────────────────────────
    $_font = DRUPAL_ROOT . '/sites/default/files/ozkcontent/Rambla-Bold.ttf';
    foreach (['square_profielfoto', 'square_profielfoto_crop', 'square_0260', 'square_0260_naam'] as $_style_name) {
        $_style_def = image_style_load($_style_name);
        if (!$_style_def) continue;
        $_style_uri = image_style_path($_style_name, $dst_uri);
        $_style_dst = drupal_realpath($_style_uri);
        @mkdir(dirname($_style_dst), 0775, TRUE);
        if (!file_exists($_style_dst) || filesize($_style_dst) < 1000) {
            image_style_create_derivative($_style_def, $dst_uri, $_style_uri);
            wachthond($extdebug, 3, 'derivative aangemaakt', $_style_name);
        }
        if ($_style_name === 'square_0260_naam' && !empty($_voornaam) && file_exists($_style_dst)) {
            exec('magick ' . escapeshellarg($_style_dst) .
                ' -font ' . escapeshellarg($_font) .
                ' -pointsize 21 -fill "#333333"' .
                ' -gravity South -annotate +0+37 ' . escapeshellarg($_voornaam) .
                ' ' . escapeshellarg($_style_dst));
            wachthond($extdebug, 3, 'voornaam in polaroid geschreven', $_voornaam);
        }
    }
    $t_stap = $_tp('5+6. voornaam + derivatives', $t_stap);

    // ── 7. fot_update + fot_status ────────────────────────────────────────────
    $new_fot_update = date('YmdHis');
    CRM_Core_DAO::executeQuery(
        'INSERT INTO civicrm_value_intake_181 (entity_id, fot_update_2253, fot_status_1798)
         VALUES (%1, %2, 2)
         ON DUPLICATE KEY UPDATE fot_update_2253 = %2, fot_status_1798 = 2',
        [1 => [(int) $contact_id, 'Integer'], 2 => [$new_fot_update, 'String']]
    );
    wachthond($extdebug, 3, 'fot_update + fot_status bijgewerkt', $new_fot_update);
    $t_stap = $_tp('7. fot_update + fot_status SQL', $t_stap);

    // ── 8. Meta-ophalen (naam, kampkort, kampnaam) ────────────────────────────
    $display_name     = '(onbekend)';
    $ditjaar_kampkort = NULL;
    $ditjaar_kampnaam = NULL;
    try {
        $params_contact_naam = [
            'checkPermissions' => FALSE,
            'debug'            => FALSE,
            'select'           => ['display_name', 'first_name'],
            'where'            => [['id', '=', $contact_id]],
        ];
        wachthond($extdebug, 7, 'params_contact_naam', $params_contact_naam);
        $result_contact_naam = civicrm_api4('Contact', 'get', $params_contact_naam);
        wachthond($extdebug, 9, 'result_contact_naam', $result_contact_naam);
        $display_name     = $result_contact_naam->first()['display_name'] ?? '(onbekend)';
        $_voornaam        = ucwords($result_contact_naam->first()['first_name'] ?? '');

        $allpart_array    = function_exists('base_find_allpart') ? base_find_allpart($contact_id) : FALSE;
        $ditjaar_kampkort = $allpart_array ? ($allpart_array['result_allpart_one_kampkort'] ?? NULL) : NULL;
        $ditjaar_event_id = $allpart_array ? ($allpart_array['result_allpart_one_event_id'] ?? NULL) : NULL;
        if (!empty($ditjaar_event_id)) {
            $params_event = [
                'checkPermissions' => FALSE,
                'debug'            => FALSE,
                'select'           => ['title'],
                'where'            => [['id', '=', $ditjaar_event_id]],
            ];
            wachthond($extdebug, 7, 'params_event', $params_event);
            $result_event     = civicrm_api4('Event', 'get', $params_event);
            wachthond($extdebug, 9, 'result_event', $result_event);
            $ditjaar_kampnaam = $result_event->first()['title'] ?? NULL;
        }
    } catch (\Throwable $_metaEx) {
        wachthond($extdebug, 1, 'meta-ophalen mislukt, mail gaat door met fallback-waarden', $_metaEx->getMessage());
    }
    $t_stap = $_tp('8. meta-ophalen (naam/allpart/event)', $t_stap);

    // ── 8b. Eenmalige inloglink (OTL) richting het profielfoto-webform ────────
    // Genereer een OTL die de gebruiker ECHT in Drupal inlogt en daarna op het
    // webform landt (met cid1-prefill). Anders dan een kale checksum geeft dit een
    // Drupal-sessie, zodat de gebruiker na de upload ook bv. /account kan bereiken.
    // Faalt stil (leeg) als het contact geen Drupal-account heeft.
    $otl_fotolink = '';
    if (function_exists('ozk_onetimelogin')) {
        $_uid = CRM_Core_BAO_UFMatch::getUFId($contact_id);
        if ($_uid) {
            $_acct = user_load($_uid);
            if ($_acct) {
                $_redir = 'form/profielfoto?cid1=' . (int) $contact_id;
                $otl_fotolink = ozk_onetimelogin($_acct, '+7 day', $_redir) ?: '';
            }
        }
        wachthond($extdebug, 3, 'otl_fotolink', $otl_fotolink ?: '(geen Drupal-account/leeg)');
    }

    // ── 9+10. Mails (669 webteam + 608 indiener) ─────────────────────────────
    $tpl_params = [
        'fotoedit'      => 'https://www.onvergetelijk.nl/profielfoto',
        'fotolink'      => image_style_url('square_0260', $dst_uri),
        'user_kamplang' => $ditjaar_kampnaam ?: $ditjaar_kampkort ?: 'je kamp',
        'ozkweburl'     => 'https://www.onvergetelijk.nl',
        'user_cid'      => $contact_id,
        'otl_fotolink'  => $otl_fotolink,
        'upload_bron'   => $upload_bron,
    ];
    try {
        \CRM_Core_BAO_MessageTemplate::sendTemplate([
            'messageTemplateID' => 669,
            'contactId'         => $contact_id,
            'toEmail'           => 'webteam@onvergetelijk.nl',
            'toName'            => 'Webteam OZK',
            'from'              => 'Onvergetelijke Zomerkampen <info@onvergetelijk.nl>',
            'tplParams'         => $tpl_params,
        ]);
        wachthond($extdebug, 3, 'mail 669 webteam verzonden', $contact_id);
    } catch (\Throwable $_sendEx) {
        wachthond($extdebug, 1, 'sendTemplate 669 webteam mislukt', $_sendEx->getMessage());
    }
    $t_stap = $_tp('9. sendTemplate 669 (webteam)', $t_stap);

    $_to_email = CRM_Core_DAO::singleValueQuery(
        'SELECT email FROM civicrm_email WHERE contact_id = %1 AND is_primary = 1 LIMIT 1',
        [1 => [(int) $contact_id, 'Integer']]
    );
    wachthond($extdebug, 3, 'mail 608 toEmail', $_to_email ?: '(geen)');

    // 608 gaat ALLEEN naar de deelnemer/ouder als dit een ECHTE nieuwe foto is:
    // de hash van de ruwe upload verschilt van die van de vorige verzonden foto.
    // Zo geen 608 bij re-processing (jaaroverzicht-backfill komt hier sowieso niet),
    // retry-cron van dezelfde foto, of het opnieuw insturen van een identieke foto.
    $vorige_hash = _ozk_profielfoto_lees_fotohash($contact_id);
    $is_nieuwe_foto = ($upload_hash !== '' && $upload_hash !== $vorige_hash);
    wachthond($extdebug, 3, 'mail 608 nieuwe-foto-check',
        'nieuw=' . ($upload_hash ?: '?') . ' vorig=' . ($vorige_hash ?: '-') . ' → ' . ($is_nieuwe_foto ? 'VERSTUREN' : 'overslaan'));

    if ($_to_email && $is_nieuwe_foto) {
        try {
            \CRM_Core_BAO_MessageTemplate::sendTemplate([
                'messageTemplateID' => 608,
                'contactId'         => $contact_id,
                'toEmail'           => $_to_email,
                'from'              => 'Onvergetelijke Zomerkampen <info@onvergetelijk.nl>',
                'tplParams'         => $tpl_params,
            ]);
            wachthond($extdebug, 3, 'mail 608 indiener verzonden', $_to_email);
            // Pas ná succesvol verzenden de hash bijwerken, zodat een mislukte mail
            // de volgende keer alsnog opnieuw geprobeerd wordt.
            _ozk_profielfoto_schrijf_fotohash($contact_id, $upload_hash);
        } catch (\Throwable $_sendEx) {
            wachthond($extdebug, 1, 'sendTemplate 608 indiener mislukt', $_sendEx->getMessage());
        }
    } elseif (!$_to_email) {
        wachthond($extdebug, 1, 'mail 608 overgeslagen: geen primair e-mailadres voor contact', $contact_id);
    } else {
        wachthond($extdebug, 3, 'mail 608 overgeslagen: foto ongewijzigd t.o.v. vorige upload', $contact_id);
    }
    $_tp('10. sendTemplate 608 (indiener)', $t_stap);

    watchdog($extdebug, 'verwerk_na_move KLAAR in @ms ms voor CID @cid via @bron.',
        ['@ms' => round((microtime(TRUE) - $t_start) * 1000), '@cid' => $contact_id, '@bron' => $upload_bron], WATCHDOG_INFO);
}

/**
 * Pad naar het sidecar-bestand met de md5 van de laatst-verzonden (608) ruwe upload
 * van een contact. Bewust in private:// (geen publieke exposure).
 */
function _ozk_profielfoto_fotohash_uri($contact_id) {
    return 'private://profielfoto-hash/' . (int) $contact_id . '.md5';
}

/**
 * Lees de bewaarde foto-hash van een contact ('' als nog niet bekend).
 */
function _ozk_profielfoto_lees_fotohash($contact_id) {
    $pad = drupal_realpath(_ozk_profielfoto_fotohash_uri($contact_id));
    return ($pad && is_file($pad)) ? trim((string) file_get_contents($pad)) : '';
}

/**
 * Bewaar de foto-hash van een contact (na een succesvol verzonden 608).
 */
function _ozk_profielfoto_schrijf_fotohash($contact_id, $hash) {
    if ($hash === '') {
        return;
    }
    $dir = 'private://profielfoto-hash';
    if (file_prepare_directory($dir, FILE_CREATE_DIRECTORY)) {
        file_unmanaged_save_data($hash, _ozk_profielfoto_fotohash_uri($contact_id), FILE_EXISTS_REPLACE);
    }
}

/**
 * Implements hook_cron().
 *
 * Retry-cron voor mislukte fotoverwerkingen. Zoekt contacten met fot_status=1
 * ("in verwerking") die ouder dan 30 minuten zijn — dat wijst op een FPM-crash
 * halverwege de shutdown-functie. Per run maximaal 3 contacten om de cron
 * niet te blokkeren.
 *
 * Voorwaarde: het bestand is al opgeslagen in civicrm_contact.image_URL;
 * we leiden de lokale URI daaruit af en roepen verwerk_na_move opnieuw aan.
 */
function ozk_profielfoto_cron() {
    if (!civicrm_initialize()) {
        return;
    }

    $extdebug = 'ozk_profielfoto';
    $drempel  = date('Y-m-d H:i:s', time() - 1800); // 30 minuten geleden

    // Haal contacten op met fot_status=1 ouder dan 30 min (max 3 per cron-run).
    $rijen = CRM_Core_DAO::executeQuery(
        "SELECT entity_id, fot_update_2253
         FROM civicrm_value_intake_181
         WHERE fot_status_1798 = 1
           AND fot_update_2253 < %1
         LIMIT 3",
        [1 => [$drempel, 'String']]
    );

    while ($rijen->fetch()) {
        $contact_id = (int) $rijen->entity_id;

        // Haal image_URL op om de lokale URI te achterhalen.
        try {
            $r = civicrm_api4('Contact', 'get', [
                'checkPermissions' => FALSE,
                'select'           => ['image_URL'],
                'where'            => [['id', '=', $contact_id]],
            ]);
            $image_url = $r->first()['image_URL'] ?? '';
        }
        catch (Exception $e) {
            watchdog($extdebug, 'retry-cron: Contact.get mislukt voor CID @c: @e',
                ['@c' => $contact_id, '@e' => $e->getMessage()], WATCHDOG_ERROR);
            continue;
        }

        if (!$image_url) {
            watchdog($extdebug, 'retry-cron: geen image_URL voor CID @c — sla over.', ['@c' => $contact_id], WATCHDOG_WARNING);
            // Zet fot_status=-1 zodat we dit niet blijven proberen.
            CRM_Core_DAO::executeQuery(
                "UPDATE civicrm_value_intake_181 SET fot_status_1798 = -1 WHERE entity_id = %1",
                [1 => [$contact_id, 'Integer']]
            );
            continue;
        }

        // Vertaal de publieke URL terug naar een Drupal URI.
        $base_public = file_create_url('public://');
        if (strpos($image_url, $base_public) === 0) {
            $drupal_uri = 'public://' . substr($image_url, strlen($base_public));
        } else {
            // URL is geen publieke Drupal-URL — we kunnen niets doen.
            watchdog($extdebug, 'retry-cron: image_URL heeft onbekend schema voor CID @c: @u',
                ['@c' => $contact_id, '@u' => $image_url], WATCHDOG_WARNING);
            CRM_Core_DAO::executeQuery(
                "UPDATE civicrm_value_intake_181 SET fot_status_1798 = -1 WHERE entity_id = %1",
                [1 => [$contact_id, 'Integer']]
            );
            continue;
        }

        // Controleer of het bestand nog op schijf staat.
        $pad = drupal_realpath($drupal_uri);
        if (!$pad || !is_file($pad)) {
            watchdog($extdebug, 'retry-cron: bestand niet op schijf voor CID @c: @u',
                ['@c' => $contact_id, '@u' => $drupal_uri], WATCHDOG_WARNING);
            CRM_Core_DAO::executeQuery(
                "UPDATE civicrm_value_intake_181 SET fot_status_1798 = -1 WHERE entity_id = %1",
                [1 => [$contact_id, 'Integer']]
            );
            continue;
        }

        watchdog($extdebug, 'retry-cron: herstart verwerking voor CID @c (@u)',
            ['@c' => $contact_id, '@u' => $drupal_uri], WATCHDOG_INFO);

        try {
            _ozk_profielfoto_verwerk_na_move($drupal_uri, $contact_id, 'retry-cron');
        }
        catch (Exception $e) {
            watchdog($extdebug, 'retry-cron: verwerk_na_move mislukt voor CID @c: @e',
                ['@c' => $contact_id, '@e' => $e->getMessage()], WATCHDOG_ERROR);
        }
    }
}

/**
 * Implements hook_form_alter().
 */
function ozk_profielfoto_form_alter(&$form, &$form_state, $form_id) {
    $bundle           = isset($form['#bundle']) ? $form['#bundle'] : '';
    $is_profielfoto   = ($bundle === 'profielfoto'    || $form_id === 'profielfoto_entityform_edit_form');
    $is_profielfoto_sq = ($bundle === 'profielfoto_sq' || $form_id === 'profielfoto_sq_entityform_edit_form');

    if (!($is_profielfoto || $is_profielfoto_sq)) {
        return;
    }

    watchdog('ozk_profielfoto', "Form alter actief voor: @id (bundle: @b)", ['@id' => $form_id, '@b' => $bundle], WATCHDOG_DEBUG);

    $form['actions']['submit']['#submit'][] = '_ozk_profielfoto_profielfoto_redirect_force';

    // profielfoto_sq: altijd server-side autocrop, nooit manualcrop-UI tonen.
    // profielfoto:    schakelaar OZK_PROFIELFOTO_AUTOCROP_ALTIJD bepaalt gedrag.
    $altijd_autocrop = $is_profielfoto_sq || TRUE; // profielfoto staat ook op TRUE
    if (!defined('OZK_PROFIELFOTO_AUTOCROP_ALTIJD')) {
        define('OZK_PROFIELFOTO_AUTOCROP_ALTIJD', $altijd_autocrop);
    }

    if ($altijd_autocrop) {
        // Verberg de manualcrop-thumblist volledig via CSS en onderdruk de validatie.
        $form['#validate'][]    = '_ozk_profielfoto_crop_fout_vertalen';
        drupal_add_css(
            '.manualcrop-thumblist, .ozk-crop-hint { display:none !important; }',
            ['type' => 'inline', 'group' => CSS_THEME, 'weight' => 99]
        );
    } else {
        // Toon bijsnijden-UI met uitleg + vriendelijke foutmelding.
        $form['#validate'][]    = '_ozk_profielfoto_crop_fout_vertalen';
        $form['#after_build'][] = '_ozk_profielfoto_crop_uitleg_toevoegen';
    }

    // HEIC/HEIF accepteren: hang onze converter vooraan de upload-validators
    // van het fotoveld. Dit MOET hier (in form_alter, vóór form_builder),
    // omdat managed_file de upload afhandelt in zijn #value_callback en niet
    // in #process. Zie _ozk_profielfoto_validate_heic_naar_jpg().
    if (isset($form['field_profielfoto'])) {
        _ozk_profielfoto_heic_validator_inhaken($form['field_profielfoto']);
    }
}

/**
 * =======================================================================================
 * VALIDATE: _ozk_profielfoto_crop_fout_vertalen
 * =======================================================================================
 * Vervangt de technische manualcrop-validatiefout ("must have a cropping selection")
 * door een vriendelijke Nederlandse melding die de gebruiker uitlegt wat te doen.
 */
function _ozk_profielfoto_crop_fout_vertalen($form, &$form_state) {
    $fouten = form_get_errors();
    if (empty($fouten)) {
        return;
    }

    $bevat_crop_fout = FALSE;
    foreach ($fouten as $fout) {
        if (strpos($fout, 'must have a cropping selection') !== FALSE
            || strpos($fout, 'cropping selection') !== FALSE) {
            $bevat_crop_fout = TRUE;
            break;
        }
    }
    if (!$bevat_crop_fout) {
        return;
    }

    // Wis alle fouten en zet ze terug — met de crop-fout vervangen of onderdrukt.
    form_clear_error();
    $is_mobiel = _ozk_profielfoto_is_mobiel();

    // Drain ook de al-ge-queude sessie-berichten zodat de fout niet meer zichtbaar is.
    $sessie_fouten = drupal_get_messages('error', TRUE);
    $crop_patroon  = 'cropping selection';

    foreach ($fouten as $veld => $fout) {
        if (strpos($fout, $crop_patroon) !== FALSE) {
            if (!$is_mobiel) {
                form_set_error($veld, t('Foto nog niet bijgesneden — klik op de knop <strong>Bijsnijden</strong> onder de foto, sleep een vierkant gebied, en klik daarna op <strong>Opslaan</strong>.'));
            }
            // Op mobiel: stil weggooien, autocrop doet het server-side.
        } else {
            form_set_error($veld, $fout);
        }
    }

    // Zet sessie-foutberichten terug zonder de crop-meldingen.
    if (!empty($sessie_fouten['error'])) {
        foreach ($sessie_fouten['error'] as $bericht) {
            if (strpos($bericht, $crop_patroon) === FALSE) {
                drupal_set_message($bericht, 'error');
            }
        }
    }
}

/**
 * =======================================================================================
 * AFTER_BUILD: _ozk_profielfoto_crop_uitleg_toevoegen
 * =======================================================================================
 * Injecteert via inline JS een korte uitleg naast de bijsnijden-thumbnail, zodat de
 * gebruiker weet dat klikken op de miniatuur de cropper opent.
 */
function _ozk_profielfoto_crop_uitleg_toevoegen($form, &$form_state) {
    $js = <<<'JS'
(function ($) {
  Drupal.behaviors.ozkCropUitleg = {
    attach: function (context, settings) {
      // Voeg uitleg toe naast elke bijsnijden-thumbnail (eenmalig via .once()).
      $('.manualcrop-thumblist', context).once('ozk-crop-uitleg', function () {
        $(this).after(
          '<p class="ozk-crop-hint" style="margin-top:4px;font-size:0.9em;color:#555;">' +
          '<strong>Klik op het plaatje hierboven</strong> om de foto bij te snijden. ' +
          'Sleep daarna een vierkant gebied en klik op <em>Opslaan</em>.' +
          '</p>' +
          '<p class="ozk-crop-hint ozk-crop-hint--mobiel" style="margin-top:2px;font-size:0.85em;color:#888;">' +
          '&#128196; Tip: bijsnijden werkt het makkelijkst op een laptop of pc. Op een telefoon kan het wat lastiger zijn.' +
          '</p>'
        );
      });
    }
  };
}(jQuery));
JS;
    drupal_add_js($js, ['type' => 'inline', 'scope' => 'footer', 'weight' => 10]);
    return $form;
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_is_mobiel
 * =======================================================================================
 * Geeft TRUE als het huidige verzoek van een mobiel apparaat komt (telefoon of tablet).
 * Gebruikt de User-Agent — voldoende nauwkeurig voor de crop-beslissing.
 */
function _ozk_profielfoto_is_mobiel() {
    $ua = isset($_SERVER['HTTP_USER_AGENT']) ? $_SERVER['HTTP_USER_AGENT'] : '';
    return (bool) preg_match(
        '/Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile|Tablet/i',
        $ua
    );
}

/**
 * Kernlogica van de autocrop: werkt op een absoluut bestandspad.
 * Wordt aangeroepen vanuit zowel entityform- als webform-uploads.
 *
 * @param string        $pad      Absoluut pad naar het bronbestand (wordt IN PLACE overschreven).
 * @param object|null   $bestand  Drupal file-object (voor file_save na overschrijven); NULL = geen DB-update.
 */
function _ozk_profielfoto_autocrop_op_pad($pad, $bestand = NULL) {
    $extdebug = 'ozk_profielfoto';
    $t_start  = microtime(TRUE);
    $_t       = function($label, $t0) use ($extdebug, $t_start) {
        $ms_stap  = round((microtime(TRUE) - $t0)    * 1000);
        $ms_totaal = round((microtime(TRUE) - $t_start) * 1000);
        watchdog($extdebug, "TIMING autocrop  [@ms_totaalms] $label: @ms_stap ms",
            ['@ms_totaal' => $ms_totaal, '@ms_stap' => $ms_stap], WATCHDOG_DEBUG);
        return microtime(TRUE);
    };

    // ------------------------------------------------------------------ 0. Orientatie normaliseren
    // Bak een eventuele EXIF-rotatie IN het bestand voordat we iets meten of snijden.
    // Reden: de detector (Python/HOG) én getimagesize() werken op de rauwe pixels, maar
    // de crop hieronder draait 'magick -auto-orient' (roteert eerst). Bij een gekantelde
    // telefoonfoto verschillen die twee coördinaatruimtes → de crop valt op de verkeerde
    // plek, en de HOG-detector mist het zijwaartse gezicht (→ false positive in de
    // achtergrond, zoals bij Loa). Na normaliseren zitten detectie, geometrie en crop
    // allemaal in dezelfde, opgerichte ruimte. Alleen herschrijven als er echt rotatie is,
    // zodat we niet onnodig hercomprimeren.
    $t_stap = microtime(TRUE);
    $orient = trim((string) shell_exec('magick identify -format %[orientation] ' . escapeshellarg($pad . '[0]') . ' 2>/dev/null'));
    if ($orient !== '' && $orient !== 'TopLeft' && $orient !== 'Undefined') {
        exec('magick ' . escapeshellarg($pad . '[0]') . ' -auto-orient +repage -quality 95 ' . escapeshellarg($pad), $uo, $rvo);
        watchdog($extdebug, 'autocrop: EXIF-orientatie @o genormaliseerd voor @f', ['@o' => $orient, '@f' => basename($pad)], WATCHDOG_INFO);
        if ($bestand) {
            $bestand->filesize = filesize($pad);
        }
    }
    $t_stap = $_t('0. EXIF-orientatie', $t_stap);

    // ------------------------------------------------------------------ 0a. Werkbestand cappen
    // De grootste profielfoto-derivative is 2160px (square_profielfoto); niets heeft
    // meer nodig. Een 24MP-upload (6000×4000) door de hele pijplijn slepen is dus
    // verspilling: trage detectie/vergelijk én een onnodig grote master. We cappen
    // het werkbestand hier op 3840px langste zijde — de korte zijde blijft dan ~2560,
    // ruim genoeg voor een scherpe 2160-crop (ook bij wijdere opnames), terwijl
    // detectie toch op ≤1600 (DETECT_MAX) draait en de master sowieso op 2160² wordt
    // gecapt (geen extra opslag). Alleen verkleinen als de bron groter is (nooit upscalen).
    $WERK_MAX = 3840;
    $img_info_cap = getimagesize($pad);
    if ($img_info_cap && max($img_info_cap[0], $img_info_cap[1]) > $WERK_MAX) {
        exec('magick ' . escapeshellarg($pad . '[0]') . " -resize '{$WERK_MAX}x{$WERK_MAX}>' +repage -quality 92 " . escapeshellarg($pad), $uc, $rvc);
        watchdog($extdebug, 'autocrop: werkbestand gecapt @oud → ≤@max px voor @f',
            ['@oud' => $img_info_cap[0] . 'x' . $img_info_cap[1], '@max' => $WERK_MAX, '@f' => basename($pad)], WATCHDOG_INFO);
        if ($bestand) {
            $bestand->filesize = filesize($pad);
        }
    }
    $t_stap = $_t('0a. werkbestand cappen (≤' . $WERK_MAX . 'px)', $t_stap);

    // ------------------------------------------------------------------ 1. Gezicht detecteren
    // Detectie op origineel of max 4320px (2×2160) zodat kleine gezichten goed gevonden
    // worden. Alleen verkleinen als bron groter is dan 4320px (zelden bij normale uploads).
    $script       = dirname(__FILE__) . '/bin/ozk-facedetect';
    // Minimale gezichtsgrootte als fractie van de korte zijde. Eén bron van waarheid:
    // doorgegeven aan de detector (filtert false positives al in Python) én hergebruikt
    // door de plausibiliteitsguard hieronder (sectie 3a) als backstop.
    $min_face_ratio = 0.08;
    $_bestandsnaam  = $bestand ? $bestand->filename : basename($pad);

    // Detectie met één retry. Vindt de detector upright geen gezicht maar wél na
    // (virtueel) roteren, dan geeft ozk-facedetect 'suggested_rotation' terug. Zo
    // ondervangen we foto's die fysiek gedraaid zijn maar GEEN EXIF-orientatie dragen
    // (bv. na app-export of HEIC→JPEG-conversie): sectie 0 ziet daar niets, de detector
    // wél. We bakken die rotatie dan in (net als EXIF) en detecteren één keer opnieuw
    // op de nu rechtopstaande foto, zodat de coördinaten gewoon kloppen.
    $gezicht     = NULL;
    $gezicht_raw = NULL;
    $schaal      = 1.0;
    for ($poging = 0; $poging <= 1; $poging++) {
        $tmp_detect   = $pad . '.detect.jpg';
        $img_info_pre = getimagesize($pad);
        $schaal       = 1.0;
        // Detectie op origineel of max 4320px (2×2160) zodat kleine gezichten goed
        // gevonden worden. Alleen verkleinen als bron groter is dan 4320px.
        if ($img_info_pre && max($img_info_pre[0], $img_info_pre[1]) > 4320) {
            exec('magick ' . escapeshellarg($pad . '[0]') . " -resize '4320x4320>' " . escapeshellarg($tmp_detect));
            $tmp_info = getimagesize($tmp_detect);
            if ($tmp_info) {
                $schaal = $img_info_pre[0] / $tmp_info[0];
            }
            $detect_pad = $tmp_detect;
        } else {
            $detect_pad = $pad;
        }
        $t_stap = $_t('1. pre-shrink (orig ' . ($img_info_pre[0] ?? '?') . 'x' . ($img_info_pre[1] ?? '?') . ' → ' . basename($detect_pad) . ', poging ' . $poging . ')', $t_stap);

        // De detector draait meerdere engines parallel (HOG + YuNet) en geeft het beste,
        // door consensus bevestigde gezicht terug; te kleine kandidaten (false positives)
        // worden binnen het script al weggefilterd op $min_face_ratio.
        $cmd_detect = escapeshellarg($script) . ' ' . escapeshellarg($detect_pad) . ' ' . escapeshellarg((string) $min_face_ratio);
        $json_raw   = shell_exec($cmd_detect);
        $t_stap = $_t('2. facedetect (HOG+YuNet)', $t_stap);

        if (file_exists($tmp_detect)) {
            @unlink($tmp_detect);
        }
        $gezicht_raw = $json_raw ? json_decode($json_raw, TRUE) : NULL;

        // Coördinaten terugschalen naar originele afmetingen
        $gezicht = $gezicht_raw;
        if (!empty($gezicht_raw['found']) && $schaal > 1.0) {
            $gezicht = [
                'found'  => TRUE,
                'top'    => (int) round($gezicht_raw['top']    * $schaal),
                'right'  => (int) round($gezicht_raw['right']  * $schaal),
                'bottom' => (int) round($gezicht_raw['bottom'] * $schaal),
                'left'   => (int) round($gezicht_raw['left']   * $schaal),
            ];
        }

        // Gevonden → klaar. Anders: als de detector een rotatie voorstelt, die in de
        // eerste poging inbakken en opnieuw detecteren op de rechtopstaande foto.
        if (!empty($gezicht['found'])) {
            break;
        }
        $rot = !empty($gezicht_raw['suggested_rotation']) ? (int) $gezicht_raw['suggested_rotation'] : 0;
        if ($poging === 0 && in_array($rot, [90, 180, 270], TRUE)) {
            exec('magick ' . escapeshellarg($pad . '[0]') . ' -rotate ' . $rot . ' +repage -quality 95 ' . escapeshellarg($pad), $ur, $rvr);
            watchdog($extdebug, 'autocrop: geen EXIF maar detector stelt @d° rotatie voor → ingebakken voor @f', ['@d' => $rot, '@f' => $_bestandsnaam], WATCHDOG_INFO);
            if ($bestand) {
                $bestand->filesize = filesize($pad);
            }
            continue;
        }
        break;
    }

    if (empty($gezicht['found'])) {
        // Geen gezicht gevonden → foto ONAANGEROERD laten (volledige foto bewaren).
        // De vierkante image-styles (square_0260 = image_scale_and_crop, gecentreerd)
        // maken bij weergave alsnog een vierkant. Beter een volledige foto dan een
        // gokkende crop. (We laten alleen de evt. orientatie-normalisatie van sectie 0 staan.)
        watchdog($extdebug, 'autocrop: geen gezicht gevonden in @f → foto onaangeroerd gelaten (image-styles maken vierkant).', ['@f' => $_bestandsnaam], WATCHDOG_INFO);
        if ($bestand) {
            file_save($bestand);
        }
        return;
    }

    watchdog($extdebug, 'autocrop: gezicht gevonden top=@t right=@r bottom=@b left=@l in @f', [
        '@t' => $gezicht['top'], '@r' => $gezicht['right'],
        '@b' => $gezicht['bottom'], '@l' => $gezicht['left'],
        '@f' => $_bestandsnaam,
    ], WATCHDOG_INFO);

    // ------------------------------------------------------------------ 2. Afmetingen origineel
    $img_info = getimagesize($pad);
    if (!$img_info) {
        watchdog($extdebug, 'autocrop: getimagesize mislukt voor @f', ['@f' => $pad], WATCHDOG_WARNING);
        return;
    }
    $img_breed  = $img_info[0];
    $img_hoogte = $img_info[1];

    // ------------------------------------------------------------------ 3. Vierkant rondom gezicht berekenen
    $gz_top    = $gezicht['top'];
    $gz_right  = $gezicht['right'];
    $gz_bottom = $gezicht['bottom'];
    $gz_left   = $gezicht['left'];

    $gz_breed  = $gz_right  - $gz_left;
    $gz_hoogte = $gz_bottom - $gz_top;
    $gz_cx     = (int) round(($gz_left + $gz_right)  / 2);
    $gz_cy     = (int) round(($gz_top  + $gz_bottom) / 2);

    // ------------------------------------------------------------------ 3a. Plausibiliteitscheck
    // Een te klein "gezicht" t.o.v. de foto is vrijwel zeker een false positive: de
    // HOG-detector pikt soms een patroon in stof/achtergrond op (bv. Loa: 107 px breed
    // in een 4032 px brede foto → 2.5× padding gaf een 268 px micro-crop, extreem
    // ingezoomd). Echte portretten hier zitten op 15–30% van de korte zijde. Drempel
    // = 8% van de korte zijde; daaronder vertrouwen we de detectie niet en laten we de
    // foto ONAANGEROERD (image-styles maken alsnog een gecentreerd vierkant).
    $drempel_px = (int) round(min($img_breed, $img_hoogte) * $min_face_ratio);
    if (max($gz_breed, $gz_hoogte) < $drempel_px) {
        watchdog($extdebug, 'autocrop: gezicht te klein (@gz px < drempel @d px) in @f → waarschijnlijk false positive, foto onaangeroerd gelaten.',
            ['@gz' => max($gz_breed, $gz_hoogte), '@d' => $drempel_px, '@f' => $_bestandsnaam], WATCHDOG_WARNING);
        if ($bestand) {
            file_save($bestand);
        }
        return;
    }

    // Adaptieve crop: stuur op gezicht = 35% van de crop-hoogte zodat de
    // gezichtsverhouding constant blijft ongeacht of de bronopname al strak of
    // juist wijd is (vaste factor zoals 2.5× zoomt bij close-ups te ver in).
    $doel_fractie = 0.35;
    $gz_max       = max($gz_breed, $gz_hoogte);
    $zijde        = (int) round($gz_max / $doel_fractie);
    // Vangrails: nooit kleiner dan 1.5× gezicht (extreme close-up), minimaal 100px,
    // en nooit groter dan de kortste zijde van de foto.
    $zijde = max($zijde, (int) round($gz_max * 1.5), 100);
    $zijde = min($zijde, $img_breed, $img_hoogte);

    // Gezichtscentrum op 42% van boven zodat kruin én kin goed passen
    $crop_top  = $gz_cy - (int) round($zijde * 0.42);
    $crop_left = $gz_cx - (int) round($zijde / 2);

    // Klem binnen de afbeeldingsgrenzen
    $crop_left = max(0, min($crop_left, $img_breed  - $zijde));
    $crop_top  = max(0, min($crop_top,  $img_hoogte - $zijde));
    $zijde     = min($zijde, $img_breed, $img_hoogte);

    // ------------------------------------------------------------------ 3b. Hoofd-behoud
    // Voorkom dat de crop de kruin/kin/zijkant van het HOOFD afsnijdt terwijl het
    // origineel het hele hoofd wél bevatte (zoals bij Hannah: kruin werd weggesneden).
    // De detector geeft alleen de GEZICHTSbox, dus schatten we een ruimere hoofd-box:
    // kruin ~0.6× gezichtshoogte erboven, kin ~0.15× eronder, haar ~0.2× links/rechts.
    // Past die hoofd-box in het origineel maar niet in de huidige crop, dan vergroten
    // we het vierkant (tot het maximale = korte zijde) en centreren we op het hoofd,
    // zodat het hele hoofd behouden blijft i.p.v. een strakkere, afsnijdende crop.
    $hoofd_top    = $gz_top    - (int) round($gz_hoogte * 0.6);
    $hoofd_bottom = $gz_bottom + (int) round($gz_hoogte * 0.15);
    $hoofd_left   = $gz_left   - (int) round($gz_breed  * 0.2);
    $hoofd_right  = $gz_right  + (int) round($gz_breed  * 0.2);
    $hoofd_h      = $hoofd_bottom - $hoofd_top;
    $hoofd_w      = $hoofd_right  - $hoofd_left;
    $hoofd_cx     = (int) round(($hoofd_left + $hoofd_right)  / 2);
    $hoofd_cy     = (int) round(($hoofd_top  + $hoofd_bottom) / 2);

    $orig_bevat_hoofd  = ($hoofd_top >= 0 && $hoofd_bottom <= $img_hoogte
                          && $hoofd_left >= 0 && $hoofd_right <= $img_breed);
    $crop_bevat_hoofd  = ($crop_top <= $hoofd_top && ($crop_top + $zijde) >= $hoofd_bottom
                          && $crop_left <= $hoofd_left && ($crop_left + $zijde) >= $hoofd_right);

    if ($orig_bevat_hoofd && !$crop_bevat_hoofd) {
        // Maximaal vierkant dat het hoofd kan bevatten, begrensd door de korte zijde.
        $zijde     = min(max($zijde, $hoofd_h, $hoofd_w), $img_breed, $img_hoogte);
        $crop_left = $hoofd_cx - (int) round($zijde / 2);
        $crop_top  = $hoofd_cy - (int) round($zijde / 2);
        $crop_left = max(0, min($crop_left, $img_breed  - $zijde));
        $crop_top  = max(0, min($crop_top,  $img_hoogte - $zijde));
        watchdog($extdebug, 'autocrop: hoofd-behoud actief — crop vergroot/verschoven naar @z² om heel hoofd te behouden voor @f',
            ['@z' => $zijde, '@f' => $_bestandsnaam], WATCHDOG_INFO);
    }

    // ------------------------------------------------------------------ 4. Crop + master normaliseren naar 2160²
    // Snijd het vierkant rond het gezicht én normaliseer de master in één pass naar
    // 2160×2160 — de grootste profielfoto-derivative. Grotere crops worden verkleind
    // (scherp), kleinere opgeschaald (zoals voorheen via de aparte upscale-stap). Zo is
    // de master altijd precies groot genoeg, nooit groter. Het vierkant maakt -resize
    // 2160x2160 deterministisch 2160².
    $geometry = sprintf('%dx%d+%d+%d', $zijde, $zijde, $crop_left, $crop_top);
    $cmd_crop = sprintf(
        'magick %s -crop %s +repage -resize 2160x2160 -auto-orient -quality 92 %s',
        escapeshellarg($pad . '[0]'),
        escapeshellarg($geometry),
        escapeshellarg($pad)
    );
    exec($cmd_crop, $uitvoer, $rv);
    $t_stap = $_t('3. ImageMagick crop + resize 2160', $t_stap);

    if ($rv !== 0) {
        watchdog($extdebug, 'autocrop: ImageMagick crop mislukt (rv=@rv) voor @f', ['@rv' => $rv, '@f' => $_bestandsnaam], WATCHDOG_ERROR);
        return;
    }

    // Bestandsgrootte in DB bijwerken na overschrijven (alleen als file-object beschikbaar).
    if ($bestand) {
        $bestand->filesize = filesize($pad);
        file_save($bestand);
    }

    $t_stap = $_t('4. file_save na crop', $t_stap);
    watchdog($extdebug, 'autocrop: crop geslaagd (@g) voor @f — TOTAAL @ms ms',
        ['@g' => $geometry, '@f' => $_bestandsnaam, '@ms' => round((microtime(TRUE) - $t_start) * 1000)], WATCHDOG_INFO);
}

/**
 * Fallback: vierkante crop gecentreerd in de afbeelding (als ozk-facedetect geen gezicht vindt).
 */
function _ozk_profielfoto_autocrop_midden($pad) {
    $cmd = sprintf(
        'magick %s -gravity Center -extent "%%[fx:min(w,h)]x%%[fx:min(w,h)]" +repage -quality 92 %s',
        escapeshellarg($pad . '[0]'),
        escapeshellarg($pad)
    );
    exec($cmd, $uitvoer, $rv);
    if ($rv !== 0) {
        watchdog('ozk_profielfoto', 'autocrop_midden: ImageMagick mislukt (rv=@rv)', ['@rv' => $rv], WATCHDOG_ERROR);
    }
}

/**
 * =======================================================================================
 * HELPER: _ozk_profielfoto_heic_validator_inhaken
 * =======================================================================================
 * Loopt recursief door het field_profielfoto-formulierfragment en hangt op ELK element
 * met #upload_validators onze HEIC->JPEG-converter VOORAAN, zodat die draait vóór de
 * standaard image-validators (file_validate_is_image / file_validate_extensions).
 * Tevens staan we .heic/.heif toe in de extensie-check (defensief; na conversie heet
 * het bestand toch .jpg).
 */
function _ozk_profielfoto_heic_validator_inhaken(&$element) {
    if (!is_array($element)) {
        return;
    }

    if (isset($element['#upload_validators']) && is_array($element['#upload_validators'])) {
        // 1. Extensie toestaan (defensief).
        if (!empty($element['#upload_validators']['file_validate_extensions'][0])
            && strpos($element['#upload_validators']['file_validate_extensions'][0], 'heic') === FALSE) {
            $element['#upload_validators']['file_validate_extensions'][0] .= ' heic heif';
        }
        // 2. Converter VOORAAN (array-unie behoudt volgorde: links eerst).
        if (!isset($element['#upload_validators']['_ozk_profielfoto_validate_heic_naar_jpg'])) {
            $element['#upload_validators'] =
                ['_ozk_profielfoto_validate_heic_naar_jpg' => []]
                + $element['#upload_validators'];
        }
    }

    // Recursief door de child-elementen (taal-container + delta's).
    foreach (element_children($element) as $key) {
        _ozk_profielfoto_heic_validator_inhaken($element[$key]);
    }
}

/**
 * =======================================================================================
 * UPLOAD-VALIDATOR: _ozk_profielfoto_validate_heic_naar_jpg
 * =======================================================================================
 * Zet een geüploade HEIC/HEIF om naar JPEG. Draait als EERSTE upload-validator, terwijl
 * $file->uri nog naar de geüploade tmp-file wijst. We overschrijven die tmp-file IN PLACE
 * met de JPEG-bytes, want file_save_upload() verplaatst straks letterlijk
 * $_FILES[...]['tmp_name'] (niet $file->uri) naar de bestemming. Daarna corrigeren we
 * $file->filename naar .jpg, zodat de bestemming, de extensie-check en de latere
 * image-validators (GD/getimagesize) allemaal een geldige JPEG zien.
 *
 * Achtergrond: Drupals image_get_info() leest afmetingen via getimagesize() (ook met de
 * ImageMagick-toolkit, want image_imagemagick_get_info() gebruikt getimagesize()), en dat
 * kan HEIC niet. Daarom converteren we hier zelf met de 'magick'-binary (libheif: rw+).
 *
 * @param stdClass $file  Het in-validatie zijnde bestand (uri = geüploade tmp-file).
 * @return array          Lege array bij succes; foutmeldingen voor file_validate() bij falen.
 */
function _ozk_profielfoto_validate_heic_naar_jpg(stdClass $file) {
    $extdebug = 'ozk_profielfoto';
    $errors   = [];

    // Fysiek pad naar het (tmp-)bestand bepalen. tmp-uploads zijn vaak een kaal abs. pad.
    $pad = drupal_realpath($file->uri);
    if (empty($pad) || !is_file($pad)) {
        $pad = $file->uri;
    }
    if (!is_file($pad)) {
        return $errors;
    }

    // HEIC/HEIF herkennen: ISO-BMFF 'ftyp'-merk in de header, of de extensie.
    $kop     = (string) @file_get_contents($pad, FALSE, NULL, 0, 32);
    $is_heic = (bool) preg_match('/ftyp(heic|heix|hevc|heim|heis|hevm|hevs|mif1|msf1)/', $kop)
            || (bool) preg_match('/\.(heic|heif)$/i', $file->filename);
    if (!$is_heic) {
        return $errors; // geen HEIC -> niets doen, normale validatie loopt door
    }

    // Converteren: eerste frame, oriëntatie corrigeren, naar sRGB, metadata strippen.
    $tmp_jpg = $pad . '.ozkconv.jpg';
    $cmd     = sprintf('magick %s -auto-orient -colorspace sRGB -strip -quality 88 %s',
                       escapeshellarg($pad . '[0]'), escapeshellarg($tmp_jpg));
    exec($cmd, $uitvoer, $rv);

    if ($rv !== 0 || !is_file($tmp_jpg) || filesize($tmp_jpg) === 0) {
        @unlink($tmp_jpg);
        watchdog($extdebug, 'HEIC-conversie mislukt voor %f (rv=@rv).',
                 ['%f' => $file->filename, '@rv' => $rv], WATCHDOG_ERROR);
        $errors[] = t('Deze foto (HEIC) kon niet worden verwerkt. Sla hem op als JPG en probeer het opnieuw.');
        return $errors;
    }

    // tmp-upload IN PLACE vervangen door de JPEG (zelfde pad blijft een geldige upload).
    if (!@rename($tmp_jpg, $pad)) {
        @copy($tmp_jpg, $pad);
        @unlink($tmp_jpg);
    }

    // Naam/mime gelijktrekken zodat bestemming + vervolgvalidators .jpg zien.
    $file->filename = preg_replace('/\.(heic|heif)$/i', '.jpg', $file->filename);
    if (!preg_match('/\.jpe?g$/i', $file->filename)) {
        $file->filename .= '.jpg';
    }
    $file->filemime = 'image/jpeg';
    if (isset($file->name)) {
        $file->name = $file->filename;
    }

    watchdog($extdebug, 'HEIC/HEIF omgezet naar JPEG: %f', ['%f' => $file->filename], WATCHDOG_INFO);
    return $errors;
}

/**
 * Geforceerde redirect handler.
 */
function _ozk_profielfoto_profielfoto_redirect_force($form, &$form_state) {
    if (isset($_GET['destination'])) {
        // DEBUG: Log als er een destination wordt gedwarsboomd
        watchdog('ozk_profielfoto', "Destination '@dest' verwijderd voor redirect.", ['@dest' => $_GET['destination']], WATCHDOG_DEBUG);
        unset($_GET['destination']);
    }
    
    $form_state['redirect'] = 'account';
}

/**
 * =======================================================================================
 * HELPER (testbare seam): _ozk_profielfoto_push_image_url_naar_civicrm
 * =======================================================================================
 * Dunne wrapper voor e2e-tests: zoekt contact_id via UFMatch, doet Contact.update
 * image_URL en delegeert alle verwerking naar _ozk_profielfoto_verwerk_na_move().
 *
 * @param int         $uid         Drupal user ID
 * @param string      $image_url   Absolute URL (ongebruikt — image_url wordt afgeleid uit $drupal_uri)
 * @param string|null $drupal_uri  Drupal URI (public://...) van het bestand
 * @param string      $upload_bron 'entityform' | 'webform' | 'crm-profiel'
 */
function _ozk_profielfoto_push_image_url_naar_civicrm($uid, $image_url, $drupal_uri = NULL, $upload_bron = 'onbekend') {
    if (!civicrm_initialize()) {
        return;
    }
    $contact_id = CRM_Core_BAO_UFMatch::getContactId($uid);
    if (!$contact_id) {
        watchdog('ozk_profielfoto', 'push_image_url: geen contact_id voor UID @u', ['@u' => $uid], WATCHDOG_WARNING);
        return;
    }
    $dst_uri = $drupal_uri ?: NULL;
    if ($dst_uri) {
        $params_contact_update = [
            'checkPermissions' => FALSE,
            'debug'            => FALSE,
            'where'            => [['id', '=', $contact_id]],
            'values'           => ['image_URL' => file_create_url($dst_uri)],
        ];
        civicrm_api4('Contact', 'update', $params_contact_update);
    }
    if ($dst_uri) {
        _ozk_profielfoto_verwerk_na_move($dst_uri, $contact_id, $upload_bron);
    }
}


